        if crosshairColorConnection then crosshairColorConnection:Disconnect() end
        setButtonActive(buttons.crosshair, false)
    else
        crosshairActive = true
        createCrosshair()
        setButtonActive(buttons.crosshair, true)
    end
    saveStates()
end

