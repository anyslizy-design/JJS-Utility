-- Функция обновления текста кнопки с учётом бинда
local function updateButtonText(button, baseText, func)
	local keyCode = bindingFuncs[func]
	if keyCode then
		-- Получаем имя клавиши (например, "Q")
		local keyName = keyCode.Name:gsub("KeyCode%.", "")
		button.Text = baseText .. " [" .. keyName .. "]"
	else
		button.Text = baseText
	end
end

-- Функция закрытия меню (используется для Leave)
local function closeMenu()
	if not menuOpen then return end

	local tweenInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	local goal = {BackgroundTransparency = 1, TextTransparency = 1}

	for _, v in ipairs(menuGui:GetDescendants()) do
		if v:IsA("Frame") or v:IsA("TextLabel") or v:IsA("TextButton") then
			local tween = TweenService:Create(v, tweenInfo, goal)
			tween:Play()
		end
	end

	task.wait(0.3)
	menuGui:Destroy()
	menuOpen = false
	menuGui = nil
end

