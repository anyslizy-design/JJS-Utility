local function startBindingForFunction(func, button, baseText)
	if isBinding then
		hideBindingPrompt()
		isBinding = false
		bindingFunc = nil
	end
	isBinding = true
	bindingFunc = func
	bindingButton = button
	bindingBaseText = baseText
	showBindingPrompt()
end

-- Обработчик ввода (глобальный, для биндов и назначения)
UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end

	-- Режим назначения бинда
	if isBinding then
		if input.UserInputType == Enum.UserInputType.Keyboard then
			local key = input.KeyCode
			if key ~= Enum.KeyCode.Unknown then
				-- Удаляем старый бинд для этой функции
				local oldKey = bindingFuncs[bindingFunc]
				if oldKey then
					bindings[oldKey] = nil
					bindingFuncs[bindingFunc] = nil
				end
				-- Добавляем новый
				bindings[key] = bindingFunc
				bindingFuncs[bindingFunc] = key
				-- Обновляем текст кнопки
				if bindingButton and bindingBaseText then
					updateButtonText(bindingButton, bindingBaseText, bindingFunc)
				end
				hideBindingPrompt()
				isBinding = false
				bindingFunc = nil
				bindingButton = nil
				bindingBaseText = nil
			end
		end
		return
	end

	-- Обычные бинды
	if bindings[input.KeyCode] then
		bindings[input.KeyCode]()
	end

	-- Открытие/закрытие меню по P
	if input.KeyCode == Enum.KeyCode.P then
		if menuOpen then
			closeMenu()
		else
			openMenu()
		end
	end

	-- Закрытие по RightShift
	if input.KeyCode == Enum.KeyCode.RightShift and menuOpen then
		closeMenu()
	end
end)

