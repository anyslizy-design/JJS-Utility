	-- Функция эффекта Doza (быстрое мигание радугой)
	local function toggleDoza()
		if dozaActive then
			-- Выключить
			dozaActive = false
			if dozaGui then
				dozaGui:Destroy()
				dozaGui = nil
			end
		else
			-- Включить
			dozaActive = true
			dozaGui = Instance.new("ScreenGui")
			dozaGui.Name = "DozaEffect"
			dozaGui.ResetOnSpawn = false
			dozaGui.Parent = PlayerGui

			local frame = Instance.new("Frame")
			frame.Size = UDim2.new(1, 0, 1, 0)
			frame.Position = UDim2.new(0, 0, 0, 0)
			frame.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
			frame.BorderSizePixel = 0
			frame.Parent = dozaGui

			local colors = {
				Color3.fromRGB(255, 0, 0),
				Color3.fromRGB(255, 127, 0),
				Color3.fromRGB(255, 255, 0),
				Color3.fromRGB(0, 255, 0),
				Color3.fromRGB(0, 0, 255),
				Color3.fromRGB(75, 0, 130),
				Color3.fromRGB(148, 0, 211)
			}

			local index = 1
			task.spawn(function()
				while dozaActive and dozaGui and dozaGui.Parent do
					frame.BackgroundColor3 = colors[index]
					index = index % #colors + 1
					task.wait(0.1)  -- быстрое мигание
				end
				if dozaGui and dozaGui.Parent then
					dozaGui:Destroy()
					dozaGui = nil
				end
			end)
		end
	end

	dozaButton.MouseButton1Click:Connect(toggleDoza)

	-- Перетаскивание окна
	local dragging = false
	local dragInput, dragStart, startPos

	local function updateDrag(input)
		local delta = input.Position - dragStart
		mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
	end

	mainFrame.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = mainFrame.Position

			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)

	mainFrame.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			dragInput = input
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if input == dragInput and dragging then
			updateDrag(input)
		end
	end)

	menuOpen = true
end

-- Функция закрытия меню
local function closeMenu()
	if not menuOpen then return end

	-- Анимация исчезновения
	local tweenInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	local goal = {BackgroundTransparency = 1, TextTransparency = 1}

	for _, v in ipairs(menuGui:GetDescendants()) do
		if v:IsA("Frame") or v:IsA("TextLabel") or v:IsA("TextButton") then
			local tween = TweenService:Create(v, tweenInfo, goal)
			tween:Play()
		end
	end

	task.wait(0.3)
	menuGui:Destroy()
	menuOpen = false
	menuGui = nil
end

-- Обработчик клавиш
UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end

	-- L: открыть/закрыть меню
	if input.KeyCode == Enum.KeyCode.L then
		if menuOpen then
			closeMenu()
		else
			openMenu()
		end
	end

	-- RightShift: закрыть меню (если открыто)
	if input.KeyCode == Enum.KeyCode.RightShift and menuOpen then
		closeMenu()
	end
end)

-- Приветствие при запуске
showWelcome()
