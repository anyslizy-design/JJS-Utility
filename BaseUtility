        clone.HumanoidRootPart.Anchored = true
        local camera = viewport.CurrentCamera
        camera.CFrame = CFrame.new(clone.HumanoidRootPart.Position + Vector3.new(4,2,4), clone.HumanoidRootPart.Position)
    end

    updateModel()
    LocalPlayer.CharacterAdded:Connect(updateModel)

    -- Перетаскивание панели
    local function updateDrag(input)
        local delta = input.Position - babyDragStart
        frame.Position = UDim2.new(babyStartPos.X.Scale, babyStartPos.X.Offset + delta.X,
                                   babyStartPos.Y.Scale, babyStartPos.Y.Offset + delta.Y)
    end

    dragBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            babyDragging = true
            babyDragStart = input.Position
            babyStartPos = frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    babyDragging = false
                end
            end)
        end
    end)

    dragBar.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            babyDragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == babyDragInput and babyDragging then
            updateDrag(input)
        end
    end)
end

