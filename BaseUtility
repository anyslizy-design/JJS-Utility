		local restoreButton = Instance.new("TextButton")
		restoreButton.Size = UDim2.new(0, 30, 1, 0)
		restoreButton.Position = UDim2.new(1, -30, 0, 0)
		restoreButton.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
		restoreButton.Text = "-"
		restoreButton.TextColor3 = Color3.fromRGB(255, 255, 255)
		restoreButton.TextScaled = true
		restoreButton.Font = Enum.Font.GothamBold
		restoreButton.Parent = minimizedBar

		local restoreCorner = Instance.new("UICorner")
		restoreCorner.CornerRadius = UDim.new(0, 5)
		restoreCorner.Parent = restoreButton

		-- Кнопка закрыть
		local closeBarButton = Instance.new("TextButton")
		closeBarButton.Size = UDim2.new(0, 30, 1, 0)
		closeBarButton.Position = UDim2.new(1, -60, 0, 0)
		closeBarButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
		closeBarButton.Text = "X"
		closeBarButton.TextColor3 = Color3.fromRGB(255, 255, 255)
		closeBarButton.TextScaled = true
		closeBarButton.Font = Enum.Font.GothamBold
		closeBarButton.Parent = minimizedBar

		local closeBarCorner = Instance.new("UICorner")
		closeBarCorner.CornerRadius = UDim.new(0, 5)
		closeBarCorner.Parent = closeBarButton

		-- Функции кнопок
		restoreButton.MouseButton1Click:Connect(function()
			isMinimized = false
			minimizedBar.Visible = false
			mainFrame.Visible = true
		end)

		closeBarButton.MouseButton1Click:Connect(function()
			unloadScript()
		end)

		-- Перетаскивание свернутой панели
		local barDragging = false
		local barDragStart, barStartPos

		minimizedBar.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 and input.Position then
				-- Не перетаскиваем, если нажата кнопка (restore или close)
				local pos = input.Position
				local relativePos = minimizedBar.AbsolutePosition
				local x = pos.X - relativePos.X
				if x < minimizedBar.AbsoluteSize.X - 60 then  -- область не кнопок
					barDragging = true
					barDragStart = pos
					barStartPos = minimizedBar.Position
				end
				input.Changed:Connect(function()
					if input.UserInputState == Enum.UserInputState.End then
						barDragging = false
					end
				end)
			end
		end)

		minimizedBar.InputChanged:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseMovement then
				barDragInput = input
			end
		end)

		UserInputService.InputChanged:Connect(function(input)
			if input == barDragInput and barDragging then
				local delta = input.Position - barDragStart
				minimizedBar.Position = UDim2.new(barStartPos.X.Scale, barStartPos.X.Offset + delta.X, barStartPos.Y.Scale, barStartPos.Y.Offset + delta.Y)
			end
		end)

	else
		minimizedBar.Visible = true
	end
end

