-- Функция имитации нажатия клавиш (для Leave)
local function pressKey(keyCode)
	local success = pcall(function()
		if syn and syn.virtual_input then
			syn.virtual_input.KeyDown(keyCode)
			task.wait(0.05)
			syn.virtual_input.KeyUp(keyCode)
		elseif VirtualInputManager then
			VirtualInputManager:SendKeyEvent(true, keyCode, false, game)
			task.wait(0.05)
			VirtualInputManager:SendKeyEvent(false, keyCode, false, game)
		else
			warn("Virtual input not supported for key:", keyCode)
		end
	end)
	if not success then
		warn("Failed to press key:", keyCode)
	end
end

-- Функция Leave (выход из игры через меню)
local function leaveGame()
	task.spawn(function()
		pressKey(Enum.KeyCode.Escape)
		task.wait(0.1)
		pressKey(Enum.KeyCode.L)
		task.wait(0.1)
		pressKey(Enum.KeyCode.Return)
	end)
end

