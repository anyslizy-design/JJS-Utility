-- Функция начала назначения бинда для конкретной функции
local function startBindingForFunction(func)
	if isBinding then
		hideBindingPrompt()
		isBinding = false
		bindingFunc = nil
	end
	isBinding = true
	bindingFunc = func
	showBindingPrompt()
end

-- Обработчик глобального ввода (для биндов и назначения)
UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end

	-- Режим назначения бинда
	if isBinding then
		-- Если нажата клавиша (не мышка)
		if input.UserInputType == Enum.UserInputType.Keyboard then
			local key = input.KeyCode
			if key ~= Enum.KeyCode.Unknown then
				-- Удаляем предыдущий бинд для этой функции (если был)
				for k, v in pairs(bindings) do
					if v == bindingFunc then
						bindings[k] = nil
						break
					end
				end
				-- Устанавливаем новый бинд
				bindings[key] = bindingFunc
				hideBindingPrompt()
				isBinding = false
				bindingFunc = nil
			end
		end
		return
	end

	-- Обработка обычных хоткеев
	if bindings[input.KeyCode] then
		bindings[input.KeyCode]()
	end

	-- Открытие/закрытие меню по L (если не в режиме назначения)
	if input.KeyCode == Enum.KeyCode.L then
		if menuOpen then
			closeMenu()
		else
			openMenu()
		end
	end

	-- Закрытие меню по RightShift
	if input.KeyCode == Enum.KeyCode.RightShift and menuOpen then
		closeMenu()
	end
end)

