	if atmosphereActive then toggleAtmosphere() end
	if chinaHatActive then toggleChinaHat() end
	if customFogActive then toggleCustomFog() end
	if jumpCircleActive then toggleJumpCircle() end
	if targetHudEnabled then toggleTargetHud() end
	if espEnabled then toggleESP() end
	
	-- Удаляем GUI
	if menuGui then menuGui:Destroy() end
	if minimizedBar then minimizedBar:Destroy() end
	if watermarkGui then watermarkGui:Destroy() end
	
	-- Очищаем бинды
	bindings = {}
	bindingFuncs = {}
end

