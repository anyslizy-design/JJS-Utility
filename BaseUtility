-- TP Behind
local function tpBehind()
    local char = LocalPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local closest, dist = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local d = (p.Character.HumanoidRootPart.Position - root.Position).Magnitude
            if d < dist then dist = d; closest = p end
        end
    end
    if closest and closest.Character then
        local targetRoot = closest.Character.HumanoidRootPart
        local behind = targetRoot.Position - targetRoot.CFrame.LookVector * 5
        root.CFrame = CFrame.new(behind, behind + targetRoot.CFrame.LookVector)
    end
end

