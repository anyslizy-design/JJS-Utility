-- Вспомогательная функция для обновления текста кнопки
local function updateButtonText(button, baseText, func)
	local keyCode = bindingFuncs[func]
	if keyCode then
		local keyName = keyCode.Name:gsub("KeyCode%.", "")
		button.Text = baseText .. " [" .. keyName .. "]"
	else
		button.Text = baseText
	end
end

-- Имитация нажатия клавиш (для Leave)
local function pressKey(keyCode)
	local success = pcall(function()
		if syn and syn.virtual_input then
			syn.virtual_input.KeyDown(keyCode)
			task.wait(0.05)
			syn.virtual_input.KeyUp(keyCode)
		elseif VirtualInputManager then
			VirtualInputManager:SendKeyEvent(true, keyCode, false, game)
			task.wait(0.05)
			VirtualInputManager:SendKeyEvent(false, keyCode, false, game)
		else
			warn("Virtual input not supported")
		end
	end)
end

-- Leave
local function leaveGame()
	task.spawn(function()
		pressKey(Enum.KeyCode.Escape)
		task.wait(0.1)
		pressKey(Enum.KeyCode.L)
		task.wait(0.1)
		pressKey(Enum.KeyCode.Return)
	end)
end

