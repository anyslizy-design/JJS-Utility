-- Функция имитации нажатия клавиш (улучшенная для Xeno)
local function pressKey(keyCode)
    local success = pcall(function()
        if syn and syn.virtual_input then
            syn.virtual_input.KeyDown(keyCode)
            task.wait(0.05)
            syn.virtual_input.KeyUp(keyCode)
        elseif VirtualInputManager then
            VirtualInputManager:SendKeyEvent(true, keyCode, false, game)
            task.wait(0.05)
            VirtualInputManager:SendKeyEvent(false, keyCode, false, game)
        else
            -- Альтернативный метод для Xeno (через mouse)
            local mouse = LocalPlayer:GetMouse()
            if mouse then
                mouse:Button1Down(Vector2.new(0,0))
                task.wait(0.05)
                mouse:Button1Up(Vector2.new(0,0))
            end
            warn("Virtual input not supported, trying mouse click")
        end
    end)
    if not success then
        warn("Failed to press key:", keyCode)
    end
end

