	brim.CanCollide = false
	brim.Anchored = false
	brim.Parent = model

	local top = Instance.new("Part")
	top.Name = "Top"
	top.Shape = Enum.PartType.Cylinder
	top.Size = Vector3.new(2.5, 1.5, 2.5)
	top.Material = Enum.Material.Neon
	top.Transparency = 0.3
	top.CanCollide = false
	top.Anchored = false
	top.Parent = model

	brim.Position = head.Position + Vector3.new(0, 0.5, 0)
	top.Position = brim.Position + Vector3.new(0, 1, 0)

	local weld = Instance.new("Weld")
	weld.Part0 = head
	weld.Part1 = brim
	weld.C0 = CFrame.new(0, 0.5, 0)
	weld.Parent = brim

	local weld2 = Instance.new("Weld")
	weld2.Part0 = brim
	weld2.Part1 = top
	weld2.C0 = CFrame.new(0, 1, 0)
	weld2.Parent = top

	model.Parent = character

	local colors = {
		Color3.fromRGB(255, 0, 0),
		Color3.fromRGB(255, 127, 0),
		Color3.fromRGB(255, 255, 0),
		Color3.fromRGB(0, 255, 0),
		Color3.fromRGB(0, 0, 255),
		Color3.fromRGB(75, 0, 130),
		Color3.fromRGB(148, 0, 211)
	}
	local index = 1
	local nextColor = colors[2]
	local t = 0
	local speed = 0.5

	if hatColorConnection then
		hatColorConnection:Disconnect()
	end
	hatColorConnection = RunService.RenderStepped:Connect(function(dt)
		if not model or not model.Parent then
			hatColorConnection:Disconnect()
			hatColorConnection = nil
			return
		end
		t = t + dt * speed
		if t >= 1 then
			t = 0
			index = index % #colors + 1
			nextColor = colors[(index % #colors) + 1]
		end
		local currentColor = colors[index]:Lerp(nextColor, t)
		brim.Color = currentColor
		top.Color = currentColor
	end)

	return model
end

