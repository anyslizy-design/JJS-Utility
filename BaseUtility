-- ========== LEAVE BUTTON FUNCTIONALITY ==========
-- Simulate key presses: Escape, L, Enter with 100ms intervals
local function simulateKeyPress(keyCode)
	local vim = game:GetService("VirtualInputManager")
	vim:SendKeyEvent(true, keyCode, false, game)
	task.wait(0.05)  -- small hold time
	vim:SendKeyEvent(false, keyCode, false, game)
end

leaveButton.MouseButton1Click:Connect(function()
	simulateKeyPress(Enum.KeyCode.Escape)
	task.wait(0.1)  -- 100ms delay
	
	simulateKeyPress(Enum.KeyCode.L)
	task.wait(0.1)
	
	simulateKeyPress(Enum.KeyCode.Return)
end)

