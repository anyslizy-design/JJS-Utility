-- ESP функции
local function createESPForPlayer(player)
	if player == LocalPlayer then return end
	if not player.Character then return end

	local root = player.Character:FindFirstChild("HumanoidRootPart")
	if not root then return end

	-- Используем Drawing
	local box = Drawing.new("Square")
	box.Thickness = 1
	box.Color = Color3.fromRGB(255, 255, 255)
	box.Filled = false
	box.Visible = true

	local name = Drawing.new("Text")
	name.Size = 16
	name.Center = true
	name.Outline = true
	name.Color = Color3.fromRGB(255, 255, 255)
	name.Visible = true

	local distance = Drawing.new("Text")
	distance.Size = 14
	distance.Center = true
	distance.Outline = true
	distance.Color = Color3.fromRGB(200, 200, 200)
	distance.Visible = true

	espDrawings[player] = {
		box = box,
		name = name,
		dist = distance
	}
end

local function updateESP()
	if not espEnabled then return end

	-- Удаляем рисования для игроков, которые вышли
	for player, drawings in pairs(espDrawings) do
		if not player or not player.Parent then
			drawings.box:Remove()
			drawings.name:Remove()
			drawings.dist:Remove()
			espDrawings[player] = nil
		end
	end

	-- Добавляем новых игроков
	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer and not espDrawings[player] then
			createESPForPlayer(player)
		end
	end

	-- Обновляем позиции всех рисований
	for player, drawings in pairs(espDrawings) do
		if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
			local root = player.Character.HumanoidRootPart
			local pos = root.Position
			local vector, onScreen = Camera:WorldToViewportPoint(pos)

			if onScreen then
				local scale = 1 / (vector.Z * 0.1)  -- примерный размер
				local size = math.clamp(200 * scale, 30, 200)
				local boxSize = Vector2.new(size, size * 2)
				local boxPos = Vector2.new(vector.X - boxSize.X/2, vector.Y - boxSize.Y/2)

				drawings.box.Position = boxPos
				drawings.box.Size = boxSize

				drawings.name.Position = Vector2.new(vector.X, vector.Y - boxSize.Y/2 - 20)
				drawings.name.Text = player.Name

				local dist = math.floor((LocalPlayer.Character.HumanoidRootPart.Position - pos).Magnitude)
				drawings.dist.Position = Vector2.new(vector.X, vector.Y + boxSize.Y/2 + 5)
				drawings.dist.Text = tostring(dist) .. "m"
			else
				drawings.box.Visible = false
				drawings.name.Visible = false
				drawings.dist.Visible = false
			end
		else
			drawings.box.Visible = false
			drawings.name.Visible = false
			drawings.dist.Visible = false
		end
	end
end

local function toggleESP()
	if espEnabled then
		espEnabled = false
		-- Удаляем все рисования
		for _, drawings in pairs(espDrawings) do
			drawings.box:Remove()
			drawings.name:Remove()
			drawings.dist:Remove()
		end
		espDrawings = {}
		RunService:UnbindFromRender("ESPUpdate")
	else
		espEnabled = true
		-- Создаём рисования для существующих игроков
		for _, player in ipairs(Players:GetPlayers()) do
			if player ~= LocalPlayer then
				createESPForPlayer(player)
			end
		end
		-- Запускаем обновление
		RunService:BindToRender("ESPUpdate", Enum.RenderPriority.Camera.Value, updateESP)
	end
end

