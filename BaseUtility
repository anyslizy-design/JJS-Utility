local configFileName = "jjs_config.json"

local function saveStates()
    local states = {
        doza = dozaActive,
        atmosphere = atmosphereActive,
        nimb = nimbActive,
        customFog = customFogActive,
        m1Effect = m1EffectActive,
        aimbot = aimbotActive,
        crosshair = crosshairActive,
        bfNotif = bfNotifActive
    }
    local success, json = pcall(HttpService.JSONEncode, HttpService, states)
    if success then
        writefile(configFileName, json)
    end
end

local function loadStates()
    local states = {}
    if isfile and isfile(configFileName) then
        local json = readfile(configFileName)
        if json then
            pcall(function() states = HttpService:JSONDecode(json) end)
        end
    end
    return states
end

