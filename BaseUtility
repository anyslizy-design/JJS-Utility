    local function updateDrag(input)
        local delta = input.Position - dragStart
        local newX = startPos.X.Offset + delta.X
        local viewport = Camera.ViewportSize
        newX = math.clamp(newX, 10, viewport.X - PANEL_WIDTH - 10)
        frame.Position = UDim2.new(0, newX, startPos.Y.Scale, startPos.Y.Offset)
    end

    local function finalizeDrag()
        local currentX = frame.Position.X.Offset
        local windowLeft = (Camera.ViewportSize.X - WINDOW_WIDTH)/2
        local windowRight = windowLeft + WINDOW_WIDTH
        local leftTarget = windowLeft - PANEL_WIDTH - 10
        local rightTarget = windowRight + 10
        local distToLeft = math.abs(currentX - leftTarget)
        local distToRight = math.abs(currentX - rightTarget)
        if distToLeft < distToRight then
            frame.Position = UDim2.new(0, leftTarget, frame.Position.Y.Scale, frame.Position.Y.Offset)
        else
            frame.Position = UDim2.new(0, rightTarget, frame.Position.Y.Scale, frame.Position.Y.Offset)
        end
    end

