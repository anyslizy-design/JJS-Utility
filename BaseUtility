-- Функция телепортации за спину ближайшего игрока
local function tpBehind()
	local character = LocalPlayer.Character
	if not character then return end
	local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
	if not humanoidRootPart then return end

	local closestPlayer = nil
	local closestDistance = math.huge

	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
			local targetRoot = player.Character.HumanoidRootPart
			local dist = (targetRoot.Position - humanoidRootPart.Position).Magnitude
			if dist < closestDistance then
				closestDistance = dist
				closestPlayer = player
			end
		end
	end

	if closestPlayer and closestPlayer.Character then
		local targetRoot = closestPlayer.Character.HumanoidRootPart
		local lookVector = targetRoot.CFrame.LookVector
		local behindPos = targetRoot.Position - lookVector * 5 -- отступ 5 студий
		humanoidRootPart.CFrame = CFrame.new(behindPos, behindPos + lookVector) -- смотрим в том же направлении
	end
end

-- Функция эффекта "Doza" (радужное растяжение/сжатие по вертикали)
local function dozaEffect()
	-- Удаляем предыдущий эффект, если есть
	if PlayerGui:FindFirstChild("DozaEffect") then
		PlayerGui.DozaEffect:Destroy()
	end

	local effectGui = Instance.new("ScreenGui")
	effectGui.Name = "DozaEffect"
	effectGui.ResetOnSpawn = false
	effectGui.Parent = PlayerGui

	local frame = Instance.new("Frame")
	frame.Size = UDim2.new(1, 0, 0, 0) -- изначально высота 0
	frame.Position = UDim2.new(0, 0, 0.5, 0) -- центр по вертикали
	frame.AnchorPoint = Vector2.new(0, 0.5) -- чтобы растягивался от центра
	frame.BackgroundTransparency = 0.2
	frame.BorderSizePixel = 0
	frame.Parent = effectGui

	-- Радужный градиент
	local gradient = Instance.new("UIGradient")
	gradient.Color = ColorSequence.new{
		ColorSequenceKeypoint.new(0, Color3.fromRGB(255,0,0)),
		ColorSequenceKeypoint.new(0.17, Color3.fromRGB(255,255,0)),
		ColorSequenceKeypoint.new(0.33, Color3.fromRGB(0,255,0)),
		ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0,255,255)),
		ColorSequenceKeypoint.new(0.67, Color3.fromRGB(0,0,255)),
		ColorSequenceKeypoint.new(0.83, Color3.fromRGB(255,0,255)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(255,0,0))
	}
	gradient.Rotation = 90 -- вертикальная ориентация
	gradient.Parent = frame

	-- Анимация растяжения (30 сек) и сжатия (30 сек)
	local tweenInfo1 = TweenInfo.new(30, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	local tweenInfo2 = TweenInfo.new(30, Enum.EasingStyle.Quad, Enum.EasingDirection.In)

	local tween1 = TweenService:Create(frame, tweenInfo1, {Size = UDim2.new(1, 0, 1, 0)})
	tween1.Completed:Connect(function()
		local tween2 = TweenService:Create(frame, tweenInfo2, {Size = UDim2.new(1, 0, 0, 0)})
		tween2.Completed:Connect(function()
			effectGui:Destroy()
		end)
		tween2:Play()
	end)
	tween1:Play()
end

