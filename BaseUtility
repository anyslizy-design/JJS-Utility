-- M1 Effect
local function createM1Circle()
    if currentCircle then currentCircle:Remove() end
    currentCircle = Drawing.new("Circle")
    currentCircle.Thickness = 5
    currentCircle.NumSides = 64
    currentCircle.Radius = 0
    currentCircle.Filled = false
    currentCircle.Transparency = 1
    currentCircle.Color = Color3.new(1,0,0)
    currentCircle.Visible = true
    local startTime = tick()

    local colors = {
        Color3.fromRGB(255,0,0), Color3.fromRGB(255,127,0), Color3.fromRGB(255,255,0),
        Color3.fromRGB(0,255,0), Color3.fromRGB(0,0,255), Color3.fromRGB(75,0,130),
        Color3.fromRGB(148,0,211)
    }
    local colorIdx = 1

    local connection
    connection = RunService.RenderStepped:Connect(function()
        if not currentCircle then connection:Disconnect() return end
        local elapsed = tick() - startTime
        if elapsed > 1 then
            currentCircle:Remove()
            currentCircle = nil
            connection:Disconnect()
            return
        end
        local t = elapsed / 1
        currentCircle.Radius = t * 120
        currentCircle.Transparency = 1 - t
        colorIdx = math.floor(t * #colors) % #colors + 1
        currentCircle.Color = colors[colorIdx]
        local char = LocalPlayer.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            local pos = char.HumanoidRootPart.Position
            local v, onScreen = Camera:WorldToViewportPoint(pos)
            if onScreen then currentCircle.Position = Vector2.new(v.X, v.Y) end
        end
    end)
end

local function toggleM1Effect()
    if m1EffectActive then
        m1EffectActive = false
        if m1EffectConn then m1EffectConn:Disconnect() end
        setButtonActive(buttons.m1Effect, false)
    else
        m1EffectActive = true
        m1EffectConn = UserInputService.InputBegan:Connect(function(input, gp)
            if gp then return end
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                createM1Circle()
            end
        end)
        setButtonActive(buttons.m1Effect, true)
    end
    saveStates()
end

-- Aimbot
local function aimbotUpdate()
    local myChar = LocalPlayer.Character
    if not myChar then return end
    local myRoot = myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then return end

    local closest, dist = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local d = (p.Character.HumanoidRootPart.Position - myRoot.Position).Magnitude
            if d < dist then dist = d; closest = p end
        end
    end
    if closest and closest.Character then
        local targetRoot = closest.Character.HumanoidRootPart
        local lookAt = CFrame.lookAt(Camera.CFrame.Position, targetRoot.Position)
        Camera.CFrame = lookAt
    end
end

local function toggleAimbot()
    if aimbotActive then
        aimbotActive = false
        if aimbotConnection then aimbotConnection:Disconnect() end
        setButtonActive(buttons.aimbot, false)
    else
        aimbotActive = true
        aimbotConnection = RunService.RenderStepped:Connect(aimbotUpdate)
        setButtonActive(buttons.aimbot, true)
    end
    saveStates()
end

-- Crosshair
local function createCrosshair()
    if crosshairDrawing then return end
    crosshairDrawing = Drawing.new("Circle")
    crosshairDrawing.Thickness = 2
    crosshairDrawing.NumSides = 64
    crosshairDrawing.Radius = 8
    crosshairDrawing.Filled = false
    crosshairDrawing.Color = Color3.new(1,0,0)
    crosshairDrawing.Visible = true
    crosshairDrawing.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)

    local colors = {
        Color3.fromRGB(255,0,0), Color3.fromRGB(255,127,0), Color3.fromRGB(255,255,0),
        Color3.fromRGB(0,255,0), Color3.fromRGB(0,0,255), Color3.fromRGB(75,0,130),
        Color3.fromRGB(148,0,211)
    }
    local ci, ct, cs = 1, 0, 1.0
    local nextc = colors[2]
    crosshairColorConnection = RunService.RenderStepped:Connect(function(dt)
        if not crosshairDrawing or not crosshairActive then
            crosshairColorConnection:Disconnect()
            return
        end
        ct = ct + dt * cs
        if ct >= 1 then
            ct = 0
            ci = ci % #colors + 1
            nextc = colors[(ci % #colors) + 1]
        end
        crosshairDrawing.Color = colors[ci]:Lerp(nextc, ct)
        crosshairDrawing.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    end)
end

local function toggleCrosshair()
