-- Функция добавления обводки
local function addOutline(frame, color)
	local outline = Instance.new("UIStroke")
	outline.Color = color or Color3.fromRGB(120, 120, 120)
	outline.Thickness = 1
	outline.Parent = frame
end

-- Обводка для панелей
addOutline(leftPanel)
addOutline(rightPanel)

-- ========== ДОБАВЛЯЕМ КНОПКИ НА ЛЕВУЮ ПАНЕЛЬ ==========
local buttonSize = 40  -- высота кнопки
local buttonSpacing = 10  -- отступ между кнопками
local buttonPadding = 15  -- отступ от краёв панели

-- Функция создания кнопки
local function createButton(name, positionY, activeColor, inactiveColor, isActive)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1, -buttonPadding*2, 0, buttonSize)  -- ширина с отступами слева/справа
	btn.Position = UDim2.new(0, buttonPadding, 0, positionY)
	btn.Text = name
	btn.TextColor3 = Color3.fromRGB(255, 255, 255)
	btn.Font = Enum.Font.GothamSemibold
	btn.TextScaled = true
	btn.BorderSizePixel = 0
	btn.AutoButtonColor = false  -- отключаем стандартное свечение при наведении
	btn.Parent = leftPanel
	
	-- Скругление углов кнопки
	local btnCorner = Instance.new("UICorner")
	btnCorner.CornerRadius = UDim.new(0, 6)
	btnCorner.Parent = btn
	
	-- Задаём цвет в зависимости от состояния
	btn.BackgroundColor3 = isActive and activeColor or inactiveColor
	
	return btn
end

-- Цвета для кнопок
local activeColor = Color3.fromRGB(60, 120, 200)   -- синий (активная)
local inactiveColor = Color3.fromRGB(60, 60, 60)   -- тёмно-серый (неактивная)

-- Создаём кнопки: Combat (активна по умолчанию), Misc (неактивна)
local combatBtn = createButton("Combat", buttonPadding, activeColor, inactiveColor, true)
local miscBtn = createButton("Misc", buttonPadding*2 + buttonSize, activeColor, inactiveColor, false)

-- Функция переключения активной кнопки
local function setActiveButton(activeBtn)
	-- Сбрасываем обе кнопки на неактивный цвет
	combatBtn.BackgroundColor3 = inactiveColor
	miscBtn.BackgroundColor3 = inactiveColor
	-- Устанавливаем активной нужной кнопке активный цвет
	activeBtn.BackgroundColor3 = activeColor
end

-- Подключаем события
combatBtn.MouseButton1Click:Connect(function()
	setActiveButton(combatBtn)
	-- Здесь позже добавим отображение Combat-функций на правой панели
	print("Combat selected")
end)

miscBtn.MouseButton1Click:Connect(function()
	setActiveButton(miscBtn)
	-- Здесь позже добавим отображение Misc-функций
	print("Misc selected")
end)
