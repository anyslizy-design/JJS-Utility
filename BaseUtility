	-- Перетаскивание окна (основного)
	local dragging = false
	local dragInput, dragStart, startPos

	local function updateDrag(input)
		local delta = input.Position - dragStart
		mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
		-- Если есть свернутая панель, обновляем и её позицию при перетаскивании основного окна?
		-- Лучше не трогать, пусть позиция панели остаётся отдельной.
	end

	mainFrame.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			-- Проверяем, что клик не по кнопкам (приблизительно)
			local pos = input.Position
			local absPos = mainFrame.AbsolutePosition
			local relX = pos.X - absPos.X
			local relY = pos.Y - absPos.Y
			-- Если клик в области заголовка (например, верхние 50px и не в области кнопок)
			if relY < 50 and not (relX > mainFrame.AbsoluteSize.X - 80 and relY < 40) then
				dragging = true
				dragStart = pos
				startPos = mainFrame.Position

				input.Changed:Connect(function()
					if input.UserInputState == Enum.UserInputState.End then
						dragging = false
					end
				end)
			end
		end
	end)

	mainFrame.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement then
			dragInput = input
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if input == dragInput and dragging then
			updateDrag(input)
		end
	end)

	menuOpen = true
end

-- Глобальный обработчик ввода
UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end

	if isBinding then
		if input.UserInputType == Enum.UserInputType.Keyboard then
			local key = input.KeyCode
			if key ~= Enum.KeyCode.Unknown then
				local oldKey = bindingFuncs[bindingFunc]
				if oldKey then
					bindings[oldKey] = nil
					bindingFuncs[bindingFunc] = nil
				end
				bindings[key] = bindingFunc
				bindingFuncs[bindingFunc] = key
				if bindingButton and bindingBaseText then
					updateButtonText(bindingButton, bindingBaseText, bindingFunc)
				end
				hideBindingPrompt()
				isBinding = false
				bindingFunc = nil
				bindingButton = nil
				bindingBaseText = nil
			end
		end
		return
	end

	if bindings[input.KeyCode] then
		bindings[input.KeyCode]()
	end

	if input.KeyCode == Enum.KeyCode.P then
		if menuOpen then
			closeMenu()
		else
			openMenu()
		end
	end

	if input.KeyCode == Enum.KeyCode.RightShift and menuOpen then
		closeMenu()
	end
end)

-- Функция закрытия меню (без выгрузки скрипта)
local function closeMenu()
	if not menuOpen then return end

	local tweenInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	local goal = {BackgroundTransparency = 1, TextTransparency = 1}

	for _, v in ipairs(menuGui:GetDescendants()) do
		if v:IsA("Frame") or v:IsA("TextLabel") or v:IsA("TextButton") then
			local tween = TweenService:Create(v, tweenInfo, goal)
			tween:Play()
		end
	end

	task.wait(0.3)
	menuGui:Destroy()
	menuOpen = false
	menuGui = nil
	mainFrame = nil
end

