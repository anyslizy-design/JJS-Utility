local function toggleBlackSky()
	if blackSkyActive then
		if originalLighting.Ambient then
			Lighting.Ambient = originalLighting.Ambient
			Lighting.OutdoorAmbient = originalLighting.OutdoorAmbient
			Lighting.Brightness = originalLighting.Brightness
			Lighting.ColorShift_Top = originalLighting.ColorShift_Top
			Lighting.ColorShift_Bottom = originalLighting.ColorShift_Bottom
		end
		for _, conn in ipairs(blackSkyConnections) do
			conn:Disconnect()
		end
		blackSkyConnections = {}
		blackSkyActive = false
	else
		if next(originalLighting) == nil then
			originalLighting.Ambient = Lighting.Ambient
			originalLighting.OutdoorAmbient = Lighting.OutdoorAmbient
			originalLighting.Brightness = Lighting.Brightness
			originalLighting.ColorShift_Top = Lighting.ColorShift_Top
			originalLighting.ColorShift_Bottom = Lighting.ColorShift_Bottom
		end
		Lighting.Ambient = Color3.new(0,0,0)
		Lighting.OutdoorAmbient = Color3.new(0,0,0)
		Lighting.Brightness = 0
		Lighting.ColorShift_Top = Color3.new(0,0,0)
		Lighting.ColorShift_Bottom = Color3.new(0,0,0)

		local sky = Lighting:FindFirstChildOfClass("Sky")
		if sky then
			sky:Destroy()
		end
		local blackSky = Instance.new("Sky")
		blackSky.Name = "BlackSky"
		blackSky.SkyboxBk = "rbxasset://textures/black.png"
		blackSky.SkyboxDn = "rbxasset://textures/black.png"
		blackSky.SkyboxFt = "rbxasset://textures/black.png"
		blackSky.SkyboxLf = "rbxasset://textures/black.png"
		blackSky.SkyboxRt = "rbxasset://textures/black.png"
		blackSky.SkyboxUp = "rbxasset://textures/black.png"
		blackSky.StarCount = 0
		blackSky.MoonTextureId = ""
		blackSky.SunTextureId = ""
		blackSky.Parent = Lighting

		local atmosphere = Lighting:FindFirstChildOfClass("Atmosphere")
		if atmosphere then
			atmosphere.Density = 1
			atmosphere.Offset = 1
			atmosphere.Color = Color3.new(0,0,0)
			atmosphere.Decay = Color3.new(0,0,0)
			atmosphere.Glare = 0
		end

		blackSkyActive = true
	end
end

local function toggleChinaHat()
	if chinaHatActive then
		if hatModel then
			hatModel:Destroy()
			hatModel = nil
		end
		if hatColorConnection then
			hatColorConnection:Disconnect()
			hatColorConnection = nil
		end
		if hatCharacterAddedConn then
			hatCharacterAddedConn:Disconnect()
			hatCharacterAddedConn = nil
		end
		chinaHatActive = false
	else
		local character = LocalPlayer.Character
		if character then
			hatModel = createChinaHat(character)
		end
		hatCharacterAddedConn = LocalPlayer.CharacterAdded:Connect(function(newCharacter)
			if chinaHatActive then
				if hatModel then
					hatModel:Destroy()
					hatModel = nil
				end
				hatModel = createChinaHat(newCharacter)
			end
		end)
		chinaHatActive = true
	end
end

local function tpBehind()
	local character = LocalPlayer.Character
	if not character then return end
	local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
	if not humanoidRootPart then return end

	local closestPlayer = nil
	local closestDistance = math.huge

	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
			local targetRoot = player.Character.HumanoidRootPart
			local dist = (targetRoot.Position - humanoidRootPart.Position).Magnitude
			if dist < closestDistance then
				closestDistance = dist
				closestPlayer = player
			end
		end
	end

	if closestPlayer and closestPlayer.Character then
		local targetRoot = closestPlayer.Character.HumanoidRootPart
		local lookVector = targetRoot.CFrame.LookVector
		local behindPos = targetRoot.Position - lookVector * 5
		humanoidRootPart.CFrame = CFrame.new(behindPos, behindPos + lookVector)
	end
end

