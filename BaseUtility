-- Функция полной выгрузки скрипта
local function unloadScript()
	-- Отключаем все эффекты
	if dozaActive then
		toggleDoza()  -- выключит
	end
	if blackSkyActive then
		toggleBlackSky()
	end
	if chinaHatActive then
		toggleChinaHat()
	end
	-- Удаляем GUI
	if menuGui then
		menuGui:Destroy()
		menuGui = nil
	end
	if minimizedBar then
		minimizedBar:Destroy()
		minimizedBar = nil
	end
	-- Удаляем все соединения (они уже должны быть отсоединены, но для надёжности)
	-- Очищаем бинды
	bindings = {}
	bindingFuncs = {}
	-- Останавливаем выполнение скрипта (если возможно)
	-- В инжекторах обычно нет прямого script:Destroy(), поэтому просто завершаем функции.
	-- Можно поднять флаг остановки
	scriptRunning = false
	-- Дополнительно: если есть циклы, они проверяют этот флаг.
end

-- Обновление текста кнопки с биндом
local function updateButtonText(button, baseText, func)
	local keyCode = bindingFuncs[func]
	if keyCode then
		local keyName = keyCode.Name:gsub("KeyCode%.", "")
		button.Text = baseText .. " [" .. keyName .. "]"
	else
		button.Text = baseText
	end
end

-- Функция Leave (выход из игры)
local function leaveGame()
	LocalPlayer:Kick("Leave triggered")  -- отключает игрока от сервера
	-- Примечание: после Kick скрипт всё ещё может работать, но игрок покидает игру.
	-- Если нужно полностью остановить скрипт после выхода, можно также вызвать unloadScript()
end

