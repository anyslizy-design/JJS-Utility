		local barDrag, barStart, barStartPos, barDragInput
		minimizedBar.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				local pos = input.Position
				local relX = pos.X - minimizedBar.AbsolutePosition.X
				if relX < minimizedBar.AbsoluteSize.X - 60 then
					barDrag = true
					barStart = pos
					barStartPos = minimizedBar.Position
					input.Changed:Connect(function()
						if input.UserInputState == Enum.UserInputState.End then barDrag = false end
					end)
				end
			end
		end)
		minimizedBar.InputChanged:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseMovement then barDragInput = input end
		end)
		UserInputService.InputChanged:Connect(function(input)
			if input == barDragInput and barDrag then
				local delta = input.Position - barStart
				minimizedBar.Position = UDim2.new(barStartPos.X.Scale, barStartPos.X.Offset + delta.X,
				                                   barStartPos.Y.Scale, barStartPos.Y.Offset + delta.Y)
			end
		end)
	else
		minimizedBar.Visible = true
	end
end

