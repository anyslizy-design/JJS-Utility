-- Nimb
local function createNimb(character)
    if not character then return end
    local head = character:FindFirstChild("Head")
    if not head then return end
    if nimbModel then nimbModel:Destroy() end

    local model = Instance.new("Model")
    model.Name = "Nimb"

    local ring = Instance.new("Part")
    ring.Name = "Ring"
    ring.Shape = Enum.PartType.Cylinder
    ring.Size = Vector3.new(4, 0.2, 4)
    ring.Material = Enum.Material.Neon
    ring.Transparency = 0.3
    ring.CanCollide = false
    ring.Anchored = false
    ring.Parent = model

    local lineH = Instance.new("Part")
    lineH.Name = "LineH"
    lineH.Shape = Enum.PartType.Block
    lineH.Size = Vector3.new(4, 0.2, 0.5)
    lineH.Material = Enum.Material.Neon
    lineH.Transparency = 0.3
    lineH.CanCollide = false
    lineH.Anchored = false
    lineH.Parent = model

    local lineV = Instance.new("Part")
    lineV.Name = "LineV"
    lineV.Shape = Enum.PartType.Block
    lineV.Size = Vector3.new(0.5, 0.2, 4)
    lineV.Material = Enum.Material.Neon
    lineV.Transparency = 0.3
    lineV.CanCollide = false
    lineV.Anchored = false
    lineV.Parent = model

    local offset = CFrame.new(0, 1.5, 0)
    ring.CFrame = head.CFrame * offset
    lineH.CFrame = head.CFrame * offset
    lineV.CFrame = head.CFrame * offset

    local weldRing = Instance.new("Weld")
    weldRing.Part0 = head
    weldRing.Part1 = ring
    weldRing.C0 = offset
    weldRing.Parent = ring

    local weldH = Instance.new("Weld")
    weldH.Part0 = head
    weldH.Part1 = lineH
    weldH.C0 = offset
    weldH.Parent = lineH

    local weldV = Instance.new("Weld")
    weldV.Part0 = head
    weldV.Part1 = lineV
    weldV.C0 = offset
    weldV.Parent = lineV

    model.Parent = character

    local colors = {
        Color3.fromRGB(255,0,0), Color3.fromRGB(255,127,0), Color3.fromRGB(255,255,0),
        Color3.fromRGB(0,255,0), Color3.fromRGB(0,0,255), Color3.fromRGB(75,0,130),
        Color3.fromRGB(148,0,211)
    }
    local ci, ct, cs = 1, 0, 0.5
    local nextc = colors[2]
    if nimbColorConnection then nimbColorConnection:Disconnect() end
    nimbColorConnection = RunService.RenderStepped:Connect(function(dt)
        if not model or not model.Parent then
            nimbColorConnection:Disconnect()
            return
        end
        ct = ct + dt * cs
        if ct >= 1 then ct = 0 ci = ci % #colors + 1 nextc = colors[(ci % #colors) + 1] end
        local currentColor = colors[ci]:Lerp(nextc, ct)
        ring.Color = currentColor
        lineH.Color = currentColor
        lineV.Color = currentColor
    end)
    return model
end

local function toggleNimb()
    if nimbActive then
        if nimbModel then nimbModel:Destroy() end
        if nimbColorConnection then nimbColorConnection:Disconnect() end
        if nimbCharacterAddedConn then nimbCharacterAddedConn:Disconnect() end
        nimbActive = false
        setButtonActive(nimbButton, false)
    else
        local char = LocalPlayer.Character
        if char then nimbModel = createNimb(char) end
        nimbCharacterAddedConn = LocalPlayer.CharacterAdded:Connect(function(c)
            if nimbActive then
                if nimbModel then nimbModel:Destroy() end
                nimbModel = createNimb(c)
            end
        end)
        nimbActive = true
        setButtonActive(nimbButton, true)
    end
    saveStates()
end

