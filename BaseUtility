-- ========== LEAVE BUTTON FUNCTIONALITY ==========
local function simulateKeyPress(keyCode)
	local vim = game:GetService("VirtualInputManager")
	vim:SendKeyEvent(true, keyCode, false, game)
	task.wait(0.05)
	vim:SendKeyEvent(false, keyCode, false, game)
end

leaveButton.MouseButton1Click:Connect(function()
	simulateKeyPress(Enum.KeyCode.Escape)
	task.wait(0.1)
	simulateKeyPress(Enum.KeyCode.L)
	task.wait(0.1)
	simulateKeyPress(Enum.KeyCode.Return)
end)

-- ========== BINDING SYSTEM ==========
local UserInputService = game:GetService("UserInputService")
local isRecording = false
local recordingTarget = nil
local bindings = {}   -- button -> KeyCode

-- Status label for recording prompt
local statusLabel = Instance.new("TextLabel")
statusLabel.Size = UDim2.new(0, 300, 0, 50)
statusLabel.Position = UDim2.new(0.5, -150, 0.5, -25)
statusLabel.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
statusLabel.BackgroundTransparency = 0.3
statusLabel.Text = "Press any key to bind..."
statusLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
statusLabel.Font = Enum.Font.GothamSemibold
statusLabel.TextScaled = true
statusLabel.ZIndex = 10
statusLabel.Visible = false
statusLabel.Parent = screenGui

local statusCorner = Instance.new("UICorner")
statusCorner.CornerRadius = UDim.new(0, 8)
statusCorner.Parent = statusLabel
addOutline(statusLabel)

-- Function to update button text with bound key
local function updateButtonText(button, keyCode)
	local baseText = button.BaseText or "leave"
	local keyName = keyCode and tostring(keyCode):gsub("Enum.KeyCode.", "") or ""
	button.Text = baseText .. (keyName ~= "" and " [" .. keyName .. "]" or "")
end

-- Start recording a binding
local function startRecording(button)
	if isRecording then return end
	isRecording = true
	recordingTarget = button
	statusLabel.Visible = true
end

-- Handle input
UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end

	-- If recording, capture any keyboard key
	if isRecording and input.UserInputType == Enum.UserInputType.Keyboard then
		local keyCode = input.KeyCode
		if keyCode ~= Enum.KeyCode.Unknown then
			-- Save binding
			bindings[recordingTarget] = keyCode
			updateButtonText(recordingTarget, keyCode)

			-- Hide status and stop recording
			statusLabel.Visible = false
			isRecording = false
			recordingTarget = nil
		end
		return   -- consume input
	end

	-- If not recording, check if any bound key is pressed
	if not isRecording and input.UserInputType == Enum.UserInputType.Keyboard then
		for button, key in pairs(bindings) do
			if key == input.KeyCode then
				-- Simulate button click (executes its function)
				button:Click()
				break
			end
		end
	end
end)

-- Bind with mouse wheel click on leave button
leaveButton.MouseButton3Click:Connect(function()
	startRecording(leaveButton)
end)

-- ========== TAB SWITCHING LOGIC ==========
local function setActiveTab(activeTabName)
	for tabName, btn in pairs(buttons) do
		btn.BackgroundColor3 = (tabName == activeTabName) and activeColor or inactiveColor
	end
	for tabName, frame in pairs(contentFrames) do
		frame.Visible = (tabName == activeTabName)
	end
end

for tabName, btn in pairs(buttons) do
	btn.MouseButton1Click:Connect(function()
		setActiveTab(tabName)
	end)
end

setActiveTab("Combat")

-- ========== TOGGLE GUI WITH RIGHT SHIFT ==========
local guiVisible = true

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	
	if input.KeyCode == Enum.KeyCode.RightShift then
		guiVisible = not guiVisible
		screenGui.Enabled = guiVisible
	end
end)
