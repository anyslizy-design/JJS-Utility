-- Jump Circle
local function createJumpCircle()
	if currentCircle then
		currentCircle:Remove()
		currentCircle = nil
	end

	local circle = Drawing.new("Circle")
	circle.Thickness = 3
	circle.NumSides = 64
	circle.Radius = 0
	circle.Filled = false
	circle.Transparency = 1
	circle.Color = Color3.new(1,0,0)
	circle.Visible = true
	circle.Position = Vector2.new(0,0)
	currentCircle = circle
	circleStartTime = tick()

	local colors = {
		Color3.fromRGB(255,0,0), Color3.fromRGB(255,127,0), Color3.fromRGB(255,255,0),
		Color3.fromRGB(0,255,0), Color3.fromRGB(0,0,255), Color3.fromRGB(75,0,130),
		Color3.fromRGB(148,0,211)
	}
	local colorIdx = 1

	RunService.RenderStepped:Connect(function()
		if not currentCircle then return end
		local elapsed = tick() - circleStartTime
		if elapsed > 1 then
			currentCircle:Remove()
			currentCircle = nil
			return
		end
		-- Расширение от 0 до 100, прозрачность от 1 до 0
		local t = elapsed / 1
		local radius = t * 100
		local transparency = 1 - t
		currentCircle.Radius = radius
		currentCircle.Transparency = transparency
		-- Смена цвета
		colorIdx = math.floor(t * #colors) % #colors + 1
		currentCircle.Color = colors[colorIdx]
		-- Позиция под ногами игрока
		local char = LocalPlayer.Character
		if char and char:FindFirstChild("HumanoidRootPart") then
			local pos = char.HumanoidRootPart.Position
			local v, onScreen = Camera:WorldToViewportPoint(pos)
			if onScreen then
				currentCircle.Position = Vector2.new(v.X, v.Y)
			end
		end
	end)
end

local function toggleJumpCircle()
	if jumpCircleActive then
		jumpCircleActive = false
		if jumpCircleConn then
			jumpCircleConn:Disconnect()
			jumpCircleConn = nil
		end
	else
		jumpCircleActive = true
		local char = LocalPlayer.Character
		if char then
			local hum = char:FindFirstChild("Humanoid")
			if hum then
				jumpCircleConn = hum.Jumping:Connect(function(jumping)
					if jumping then
						createJumpCircle()
					end
				end)
			end
		end
		-- Обработка смены персонажа
		LocalPlayer.CharacterAdded:Connect(function(newChar)
			if jumpCircleActive then
				if jumpCircleConn then jumpCircleConn:Disconnect() end
				local hum = newChar:WaitForChild("Humanoid")
				jumpCircleConn = hum.Jumping:Connect(function(jumping)
					if jumping then
						createJumpCircle()
					end
				end)
			end
		end)
	end
end

-- TP Behind
local function tpBehind()
	local char = LocalPlayer.Character
	if not char then return end
	local root = char:FindFirstChild("HumanoidRootPart")
	if not root then return end

	local closest, dist = nil, math.huge
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
			local d = (p.Character.HumanoidRootPart.Position - root.Position).Magnitude
			if d < dist then dist = d; closest = p end
		end
	end
	if closest and closest.Character then
		local targetRoot = closest.Character.HumanoidRootPart
		local behind = targetRoot.Position - targetRoot.CFrame.LookVector * 5
		root.CFrame = CFrame.new(behind, behind + targetRoot.CFrame.LookVector)
	end
end

