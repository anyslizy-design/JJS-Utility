-- Нижняя панель с параметрами
local bottomPanel = Instance.new("Frame")
bottomPanel.Parent = mainFrame
bottomPanel.Size = UDim2.new(1, -20, 0, 80)
bottomPanel.Position = UDim2.new(0, 10, 1, -90)
bottomPanel.BackgroundColor3 = Color3.fromRGB(20, 40, 80)
bottomPanel.BackgroundTransparency = 0.2
bottomPanel.BorderSizePixel = 0

local bottomCorner = Instance.new("UICorner")
bottomCorner.CornerRadius = UDim.new(0, 6)
bottomCorner.Parent = bottomPanel

-- Параметры: Key, Background image, Random image, Image, Image size, Color
local params = {
    {"Key", ""},
    {"Background image", ""},
    {"Random image", ""},
    {"Image", ""},
    {"Image size", "1.07"},
    {"Color", "0.80"}
}

local xOffset = 10
for i, param in ipairs(params) do
    local paramName = param[1]
    local paramValue = param[2]
    
    -- Контейнер для одного параметра
    local paramFrame = Instance.new("Frame")
    paramFrame.Parent = bottomPanel
    paramFrame.Size = UDim2.new(0, 90, 0, 30)
    paramFrame.Position = UDim2.new(0, xOffset, 0, 10)
    paramFrame.BackgroundTransparency = 1
    
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Parent = paramFrame
    nameLabel.Size = UDim2.new(1, 0, 0, 15)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = paramName
    nameLabel.TextColor3 = Color3.fromRGB(150, 200, 255)
    nameLabel.Font = Enum.Font.Gotham
    nameLabel.TextSize = 12
    nameLabel.TextXAlignment = Enum.TextXAlignment.Left
    
    local valueLabel = Instance.new("TextLabel")
    valueLabel.Parent = paramFrame
    valueLabel.Size = UDim2.new(1, 0, 0, 15)
    valueLabel.Position = UDim2.new(0, 0, 0, 15)
    valueLabel.BackgroundTransparency = 1
    valueLabel.Text = paramValue
    valueLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    valueLabel.Font = Enum.Font.GothamSemibold
    valueLabel.TextSize = 14
    valueLabel.TextXAlignment = Enum.TextXAlignment.Left
    
    xOffset = xOffset + 100
end

