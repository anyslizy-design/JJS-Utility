-- ========== ЛОГИКА ПЕРЕКЛЮЧЕНИЯ ==========
local function setActiveButton(activeGrad, inactiveGrad, activeContent, inactiveContent)
	activeGrad.Color = ColorSequence.new(activeGradientColors)
	inactiveGrad.Color = ColorSequence.new(inactiveColor)
	activeContent.Visible = true
	inactiveContent.Visible = false
end

combatBtn.MouseButton1Click:Connect(function()
	setActiveButton(combatGradient, miscGradient, combatContent, miscContent)
end)

miscBtn.MouseButton1Click:Connect(function()
	setActiveButton(miscGradient, combatGradient, miscContent, combatContent)
end)
