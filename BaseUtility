-- Загружаем сервисы
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera

local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

-- Переменные состояния
local isMinimized = false
local menuGui = nil
local mainWindow = nil
local panel = nil
local watermark = nil
local bottomLabel = nil

-- Константы
local PANEL_WIDTH = 70
local PANEL_HEIGHT = 400          -- увеличено, чтобы вместить контент info
local WINDOW_WIDTH = 650
local WINDOW_HEIGHT = 500
local WATERMARK_WIDTH = 350
local WATERMARK_HEIGHT = 40

-- Функция сворачивания
local function minimize()
    if isMinimized then return end
    isMinimized = true
    if mainWindow then mainWindow.Visible = false end
    if panel then panel.Visible = false end
    if bottomLabel then bottomLabel.Visible = false end
end

-- Функция разворачивания
local function restore()
    if not isMinimized then return end
    isMinimized = false
    if mainWindow then mainWindow.Visible = true end
    if panel then panel.Visible = true end
    if bottomLabel then bottomLabel.Visible = true end
end

-- Создание водяного знака (без фона)
local function createWatermark()
    local gui = Instance.new("ScreenGui")
    gui.Name = "Watermark"
    gui.ResetOnSpawn = false
    gui.DisplayOrder = 10
    gui.Parent = PlayerGui

    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(0, WATERMARK_WIDTH, 0, WATERMARK_HEIGHT)
    bg.Position = UDim2.new(0.5, -WATERMARK_WIDTH/2, 0, 10)
    bg.BackgroundTransparency = 1   -- прозрачный фон
    bg.BorderSizePixel = 0
    bg.Parent = gui

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = "JJS Utility  |  0ms  |  0 FPS"
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.TextScaled = true
    label.Font = Enum.Font.GothamBlack
    label.Parent = bg

    task.spawn(function()
        while gui and gui.Parent do
            local ping = math.floor(LocalPlayer:GetNetworkPing() * 1000)
            local fps = math.floor(1 / RunService.RenderStepped:Wait())
            label.Text = string.format("JJS Utility  |  %dms  |  %d FPS", ping, fps)
            task.wait(1)
        end
    end)

    bg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            restore()
        end
    end)

    return gui, bg
end

-- Создание основного окна и нижней надписи
local function createMainWindow()
    local gui = Instance.new("ScreenGui")
    gui.Name = "ClickGUI"
    gui.ResetOnSpawn = false
    gui.DisplayOrder = 5
    gui.Parent = PlayerGui

    local window = Instance.new("Frame")
    window.Size = UDim2.new(0, WINDOW_WIDTH, 0, WINDOW_HEIGHT)
    window.Position = UDim2.new(0.5, -WINDOW_WIDTH/2, 0.5, -WINDOW_HEIGHT/2)
    window.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    window.BorderSizePixel = 0
    window.Parent = gui
    Instance.new("UICorner", window).CornerRadius = UDim.new(0, 15)

    local bottom = Instance.new("TextLabel")
    bottom.Size = UDim2.new(0, 200, 0, 40)
    bottom.Position = UDim2.new(0.5, -100, 0.5, WINDOW_HEIGHT/2 + 10)
    bottom.BackgroundTransparency = 1
    bottom.Text = "JJS Utility"
    bottom.TextColor3 = Color3.new(1,1,1)
    bottom.TextScaled = true
    bottom.Font = Enum.Font.GothamBlack
    bottom.Parent = gui

    bottom.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            minimize()
        end
    end)

    return gui, window, bottom
end

-- Создание перемещаемой панели с 6 вкладками
local function createPanel()
    local panelGui = Instance.new("ScreenGui")
    panelGui.Name = "TabPanel"
    panelGui.ResetOnSpawn = false
    panelGui.DisplayOrder = 6
    panelGui.Parent = PlayerGui

    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, PANEL_WIDTH, 0, PANEL_HEIGHT)
    frame.Position = UDim2.new(0.5, -WINDOW_WIDTH/2 - PANEL_WIDTH - 10, 0.5, -PANEL_HEIGHT/2)
    frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    frame.BorderSizePixel = 0
    frame.Parent = panelGui
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 12)

    -- Заголовок для перетаскивания
    local dragBar = Instance.new("Frame")
    dragBar.Size = UDim2.new(1, 0, 0, 20)
    dragBar.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    dragBar.BorderSizePixel = 0
    dragBar.Parent = frame
    Instance.new("UICorner", dragBar).CornerRadius = UDim.new(0, 12)

    -- Контейнер для кнопок вкладок (вертикально)
    local tabsContainer = Instance.new("Frame")
    tabsContainer.Size = UDim2.new(1, 0, 0, 6*40 + 5*5)  -- 6 кнопок с отступами
    tabsContainer.Position = UDim2.new(0, 0, 0, 25)
    tabsContainer.BackgroundTransparency = 1
    tabsContainer.Parent = frame

    local layout = Instance.new("UIListLayout", tabsContainer)
    layout.Padding = UDim.new(0, 5)
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center

    -- Функция создания квадратной кнопки с эмодзи
    local function createTabEmoji(emoji)
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(0, 40, 0, 40)
        btn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
        btn.Text = emoji
        btn.TextColor3 = Color3.new(1,1,1)
        btn.Font = Enum.Font.GothamBold
        btn.TextScaled = true
        btn.BorderSizePixel = 0
        btn.Parent = tabsContainer
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
        return btn
    end

    -- Создаём 6 кнопок
    local btnCombat = createTabEmoji("⚔️")   -- Combat
    local btnVisuals = createTabEmoji("🌠")  -- Visuals
    local btnWorld = createTabEmoji("🌍")    -- World
    local btnMisc = createTabEmoji("🌅")     -- Misc
    local btnInfo = createTabEmoji("?")      -- Info
    local btnConfigs = createTabEmoji("♾️")  -- Configs

    -- Вычисляем верхнюю часть (dragBar + отступ + кнопки + отступ до контента)
    local topHeight = 20 + 25 + (6*40 + 5*5) + 5  -- 20(drag) + 25(offset) + 265(buttons) + 5 = 315

    -- Контейнеры для контента (все по очереди)
    local function createContentContainer()
        local container = Instance.new("ScrollingFrame")
        container.Size = UDim2.new(1, 0, 1, -topHeight)
        container.Position = UDim2.new(0, 0, 0, topHeight)
        container.BackgroundTransparency = 1
        container.BorderSizePixel = 0
        container.ScrollBarThickness = 6
        container.CanvasSize = UDim2.new(0,0,0,0)
        -- Добавляем UIListLayout для автоматического расположения дочерних элементов
        local list = Instance.new("UIListLayout")
        list.Padding = UDim.new(0, 5)
        list.HorizontalAlignment = Enum.HorizontalAlignment.Center
        list.Parent = container
        return container
    end

    local contentCombat = createContentContainer()
    contentCombat.Parent = frame
    contentCombat.Visible = true

    local contentVisuals = createContentContainer()
    contentVisuals.Parent = frame
    contentVisuals.Visible = false

    local contentWorld = createContentContainer()
    contentWorld.Parent = frame
    contentWorld.Visible = false

    local contentMisc = createContentContainer()
    contentMisc.Parent = frame
    contentMisc.Visible = false

    local contentInfo = createContentContainer()
    contentInfo.Parent = frame
    contentInfo.Visible = false

    local contentConfigs = createContentContainer()
    contentConfigs.Parent = frame
    contentConfigs.Visible = false

    -- Наполняем contentInfo
    do
        -- Заголовок "info"
        local title = Instance.new("TextLabel")
        title.Size = UDim2.new(1, -10, 0, 50)
        title.BackgroundTransparency = 1
        title.Text = "info"
        title.TextColor3 = Color3.new(1,1,1)
        title.TextScaled = true
        title.Font = Enum.Font.GothamBlack
        title.Parent = contentInfo

        -- Текст описания
        local desc = Instance.new("TextLabel")
        desc.Size = UDim2.new(1, -10, 0, 200)  -- высота подбирается под текст
        desc.BackgroundTransparency = 1
        desc.Text = "JJS Utility - это лучший скрипт, который можно назвать отдельным DLC, наверное :)\nНаш скрипт-клиент предлагает вам множество функций.\nЧтобы закрыть меню, нажмите на нижнюю надпись JJS Utility.\nДля открытия нажмите на watermark."
        desc.TextColor3 = Color3.fromRGB(200,200,200)
        desc.TextScaled = true
        desc.Font = Enum.Font.Gotham
        desc.TextWrapped = true
        desc.Parent = contentInfo

        -- Подгоняем canvasSize под содержимое
        contentInfo.CanvasSize = UDim2.new(0,0,0, title.AbsoluteSize.Y + desc.AbsoluteSize.Y + 10)
        desc.Size = UDim2.new(1, -10, 0, 200)  -- оставляем фиксированную высоту, так как текст может переноситься
    end

    -- Словарь для быстрого доступа
    local tabs = {
        [btnCombat] = contentCombat,
        [btnVisuals] = contentVisuals,
        [btnWorld] = contentWorld,
        [btnMisc] = contentMisc,
        [btnInfo] = contentInfo,
        [btnConfigs] = contentConfigs
    }

    -- Функция переключения вкладки
    local function switchTab(activeBtn)
        for btn, content in pairs(tabs) do
            if btn == activeBtn then
                btn.BackgroundColor3 = Color3.fromRGB(80,80,80)
                content.Visible = true
            else
                btn.BackgroundColor3 = Color3.fromRGB(60,60,60)
                content.Visible = false
            end
        end
    end

    -- Подключаем обработчики
    btnCombat.MouseButton1Click:Connect(function() switchTab(btnCombat) end)
    btnVisuals.MouseButton1Click:Connect(function() switchTab(btnVisuals) end)
    btnWorld.MouseButton1Click:Connect(function() switchTab(btnWorld) end)
    btnMisc.MouseButton1Click:Connect(function() switchTab(btnMisc) end)
    btnInfo.MouseButton1Click:Connect(function() switchTab(btnInfo) end)
    btnConfigs.MouseButton1Click:Connect(function() switchTab(btnConfigs) end)

    -- Перетаскивание панели
    local dragging = false
    local dragStart, startPos, dragInput

    local function updateDrag(input)
        local delta = input.Position - dragStart
        local newX = startPos.X.Offset + delta.X
        local viewport = Camera.ViewportSize
        newX = math.clamp(newX, 10, viewport.X - PANEL_WIDTH - 10)
        frame.Position = UDim2.new(0, newX, startPos.Y.Scale, startPos.Y.Offset)
    end

    local function finalizeDrag()
        local currentX = frame.Position.X.Offset
        local windowLeft = (Camera.ViewportSize.X - WINDOW_WIDTH)/2
        local windowRight = windowLeft + WINDOW_WIDTH
        local leftTarget = windowLeft - PANEL_WIDTH - 10
        local rightTarget = windowRight + 10
        local distToLeft = math.abs(currentX - leftTarget)
        local distToRight = math.abs(currentX - rightTarget)
        if distToLeft < distToRight then
            frame.Position = UDim2.new(0, leftTarget, frame.Position.Y.Scale, frame.Position.Y.Offset)
        else
            frame.Position = UDim2.new(0, rightTarget, frame.Position.Y.Scale, frame.Position.Y.Offset)
        end
    end

    dragBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                    finalizeDrag()
                end
            end)
        end
    end)

    dragBar.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            dragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            updateDrag(input)
        end
    end)

    return panelGui, frame
end

-- Сборка UI
local function buildUI()
    watermark, _ = createWatermark()
    local mainGui, window, bottom = createMainWindow()
    menuGui = mainGui
    mainWindow = window
    bottomLabel = bottom
    local panelGui, panelFrame = createPanel()
    panel = panelFrame
end

-- Запуск
buildUI()
