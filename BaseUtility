-- China Hat: простая плоская поверхность (диск)
local function createChinaHat(character)
	if not character then return end
	local head = character:FindFirstChild("Head")
	if not head then return end
	if hatModel then hatModel:Destroy() end

	-- Создаём плоский цилиндр (диск)
	local hat = Instance.new("Part")
	hat.Name = "ChinaHat"
	hat.Shape = Enum.PartType.Cylinder
	hat.Size = Vector3.new(3, 0.2, 3) -- тонкий диск
	hat.Material = Enum.Material.Neon
	hat.Transparency = 0.3
	hat.CanCollide = false
	hat.Anchored = false
	hat.Position = head.Position + Vector3.new(0, 0.4, 0) -- чуть выше головы

	local weld = Instance.new("Weld")
	weld.Part0 = head
	weld.Part1 = hat
	weld.C0 = CFrame.new(0, 0.4, 0)
	weld.Parent = hat

	hat.Parent = character

	local colors = {
		Color3.fromRGB(255,0,0), Color3.fromRGB(255,127,0), Color3.fromRGB(255,255,0),
		Color3.fromRGB(0,255,0), Color3.fromRGB(0,0,255), Color3.fromRGB(75,0,130),
		Color3.fromRGB(148,0,211)
	}
	local ci, ct, cs = 1, 0, 0.5
	local nextc = colors[2]
	if hatColorConnection then hatColorConnection:Disconnect() end
	hatColorConnection = RunService.RenderStepped:Connect(function(dt)
		if not hat or not hat.Parent then hatColorConnection:Disconnect() return end
		ct = ct + dt * cs
		if ct >= 1 then ct = 0 ci = ci % #colors + 1 nextc = colors[(ci % #colors) + 1] end
		hat.Color = colors[ci]:Lerp(nextc, ct)
	end)
	return hat
end

-- China Hat toggle
local function toggleChinaHat()
	if chinaHatActive then
		if hatModel then hatModel:Destroy() end
		if hatColorConnection then hatColorConnection:Disconnect() end
		if hatCharacterAddedConn then hatCharacterAddedConn:Disconnect() end
		chinaHatActive = false
	else
		local char = LocalPlayer.Character
		if char then hatModel = createChinaHat(char) end
		hatCharacterAddedConn = LocalPlayer.CharacterAdded:Connect(function(c)
			if chinaHatActive then
				if hatModel then hatModel:Destroy() end
				hatModel = createChinaHat(c)
			end
		end)
		chinaHatActive = true
	end
end

