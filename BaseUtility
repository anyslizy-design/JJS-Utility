-- Custom M1 (ранее Jump Circle)
local function createCustomM1Circle()
    local startTime = tick()
    local circle = Drawing.new("Circle")
    circle.Thickness = 5
    circle.NumSides = 64
    circle.Radius = 0
    circle.Filled = false
    circle.Transparency = 1
    circle.Color = Color3.new(1,0,0)
    circle.Visible = true
    table.insert(customM1Circles, {circle = circle, startTime = startTime})
end

local function updateCustomM1Circles()
    local now = tick()
    for i = #customM1Circles, 1, -1 do
        local entry = customM1Circles[i]
        local circle = entry.circle
        local elapsed = now - entry.startTime
        if elapsed > 1 then
            circle:Remove()
            table.remove(customM1Circles, i)
        else
            local t = elapsed / 1
            circle.Radius = t * 120
            circle.Transparency = 1 - t
            local colorIdx = math.floor(t * 7) % 7 + 1
            circle.Color = customM1Colors[colorIdx]
            local char = LocalPlayer.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                local pos = char.HumanoidRootPart.Position
                local v, onScreen = Camera:WorldToViewportPoint(pos)
                if onScreen then
                    circle.Position = Vector2.new(v.X, v.Y)
                    circle.Visible = true
                else
                    circle.Visible = false
                end
            else
                circle.Visible = false
            end
        end
    end
end

local function toggleCustomM1()
    if customM1Active then
        customM1Active = false
        if customM1Conn then
            customM1Conn:Disconnect()
            customM1Conn = nil
        end
        for _, entry in ipairs(customM1Circles) do
            entry.circle:Remove()
        end
        customM1Circles = {}
        setButtonActive(buttons.customM1, false)
    else
        customM1Active = true
        customM1Conn = UserInputService.InputBegan:Connect(function(input, gp)
            if gp then return end
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                createCustomM1Circle()
            end
        end)
        setButtonActive(buttons.customM1, true)
    end
    saveStates()
end

-- Aimbot
local function aimbotUpdate()
    local myChar = LocalPlayer.Character
    if not myChar then return end
    local myRoot = myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then return end

    local closest, dist = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local d = (p.Character.HumanoidRootPart.Position - myRoot.Position).Magnitude
            if d < dist then dist = d; closest = p end
        end
    end
    if closest and closest.Character then
        local targetRoot = closest.Character.HumanoidRootPart
        local lookAt = CFrame.lookAt(Camera.CFrame.Position, targetRoot.Position)
        Camera.CFrame = lookAt
    end
end

local function toggleAimbot()
