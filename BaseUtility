		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			targetHudDragging = true
			targetHudDragStart = input.Position
			targetHudStartPos = frame.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then targetHudDragging = false end
			end)
		end
	end)

	dragBar.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement then
			targetHudDragInput = input
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if input == targetHudDragInput and targetHudDragging then updateDrag(input) end
	end)
end

local function updateTargetHudLoop()
	if not targetHudEnabled or not targetHudGui then return end
	
	-- Рейкаст из центра экрана
	local cam = workspace.CurrentCamera
	local viewport = cam.ViewportSize
	local ray = cam:ViewportPointToRay(viewport.X/2, viewport.Y/2)
	local params = RaycastParams.new()
	params.FilterType = Enum.RaycastFilterType.Blacklist
	-- Исключаем локального игрока и его части
	local ignoreList = {}
	if LocalPlayer.Character then
		for _, v in ipairs(LocalPlayer.Character:GetDescendants()) do
			if v:IsA("BasePart") then table.insert(ignoreList, v) end
		end
	end
	params.FilterDescendantsInstances = ignoreList

	local result = workspace:Raycast(ray.Origin, ray.Direction * 1000, params)
	if result and result.Instance then
		local part = result.Instance
		local model = part:FindFirstAncestorOfClass("Model")
		if model and model:FindFirstChild("Humanoid") then
			local player = Players:GetPlayerFromCharacter(model)
			if player and player ~= LocalPlayer then
				currentTarget = player
			else
				currentTarget = nil
			end
		else
			currentTarget = nil
		end
	else
		currentTarget = nil
	end

	if currentTarget and currentTarget.Character then
		local hum = currentTarget.Character:FindFirstChild("Humanoid")
		if hum then
			local health = math.floor(hum.Health)
			local maxHealth = math.floor(hum.MaxHealth)
			local perc = health / maxHealth
			targetHudElements.targetName.Text = currentTarget.Name
			targetHudElements.healthFill.Size = UDim2.new(perc,0,1,0)
			targetHudElements.healthText.Text = string.format("HP: %d/%d", health, maxHealth)
			return
		end
	end
	targetHudElements.targetName.Text = "No target"
	targetHudElements.healthFill.Size = UDim2.new(0,0,1,0)
	targetHudElements.healthText.Text = "HP: 0/0"
end

local function toggleTargetHud()
	if targetHudEnabled then
		targetHudEnabled = false
		if targetHudGui then targetHudGui:Destroy(); targetHudElements = {} end
		RunService:UnbindFromRender("TargetHudUpdate")
	else
		targetHudEnabled = true
		createTargetHud()
		RunService:BindToRender("TargetHudUpdate", Enum.RenderPriority.UI.Value, updateTargetHudLoop)
	end
end

-- ESP
local function createESPForPlayer(player)
	if player == LocalPlayer then return end
	if not player.Character then return end
	local root = player.Character:FindFirstChild("HumanoidRootPart")
	if not root then return end

	-- Проверяем доступность Drawing
	local success, box = pcall(Drawing.new, "Square")
	if not success then warn("Drawing not supported"); return end

	local box = Drawing.new("Square")
	box.Thickness = 1; box.Color = Color3.new(1,1,1); box.Filled = false; box.Visible = true
	local name = Drawing.new("Text")
	name.Size = 16; name.Center = true; name.Outline = true; name.Color = Color3.new(1,1,1); name.Visible = true
	local dist = Drawing.new("Text")
	dist.Size = 14; dist.Center = true; dist.Outline = true; dist.Color = Color3.fromRGB(200,200,200); dist.Visible = true

	espDrawings[player] = {box=box, name=name, dist=dist}
end

local function updateESP()
	if not espEnabled then return end
	-- Удаляем для вышедших игроков
	for p, d in pairs(espDrawings) do
		if not p or not p.Parent then
			d.box:Remove(); d.name:Remove(); d.dist:Remove()
			espDrawings[p] = nil
		end
	end
	-- Добавляем новых
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= LocalPlayer and not espDrawings[p] then createESPForPlayer(p) end
	end
	-- Обновляем позиции
	local myChar = LocalPlayer.Character
	if not myChar then return end
	local myRoot = myChar:FindFirstChild("HumanoidRootPart")
	if not myRoot then return end

	for p, d in pairs(espDrawings) do
		if p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
			local root = p.Character.HumanoidRootPart
			local pos = root.Position
			local v, onScreen = Camera:WorldToViewportPoint(pos)
			if onScreen then
				local scale = 1 / (v.Z * 0.1)
				local size = math.clamp(200 * scale, 30, 200)
				local boxSize = Vector2.new(size, size*2)
				d.box.Position = Vector2.new(v.X - boxSize.X/2, v.Y - boxSize.Y/2)
				d.box.Size = boxSize
				d.name.Position = Vector2.new(v.X, v.Y - boxSize.Y/2 - 20)
				d.name.Text = p.Name
				local distance = math.floor((myRoot.Position - pos).Magnitude)
				d.dist.Position = Vector2.new(v.X, v.Y + boxSize.Y/2 + 5)
				d.dist.Text = distance.."m"
				d.box.Visible = true; d.name.Visible = true; d.dist.Visible = true
			else
				d.box.Visible = false; d.name.Visible = false; d.dist.Visible = false
			end
		else
			d.box.Visible = false; d.name.Visible = false; d.dist.Visible = false
		end
	end
end

local function toggleESP()
	if espEnabled then
		espEnabled = false
		for _, d in pairs(espDrawings) do d.box:Remove(); d.name:Remove(); d.dist:Remove() end
		espDrawings = {}
		RunService:UnbindFromRender("ESPUpdate")
	else
		espEnabled = true
		for _, p in ipairs(Players:GetPlayers()) do
			if p ~= LocalPlayer then createESPForPlayer(p) end
		end
		RunService:BindToRender("ESPUpdate", Enum.RenderPriority.Camera.Value, updateESP)
	end
end

