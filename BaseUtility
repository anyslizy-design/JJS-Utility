    title.Size = UDim2.new(1, -10, 0, 50)
    title.Position = UDim2.new(0, 5, 0, 5)
    title.BackgroundTransparency = 1
    title.Text = "info"
    title.TextColor3 = Color3.new(1,1,1)
    title.TextScaled = true
    title.Font = Enum.Font.GothamBlack
    title.Parent = infoContainer

    local desc = Instance.new("TextLabel")
    desc.Size = UDim2.new(1, -10, 0, 200)
    desc.Position = UDim2.new(0, 5, 0, 60)
    desc.BackgroundTransparency = 1
    desc.Text = "JJS Utility - это лучший скрипт, который можно назвать отдельным DLC, наверное :)\nНаш скрипт-клиент предлагает вам множество функций.\nЧтобы закрыть меню, нажмите на нижнюю надпись JJS Utility.\nДля открытия нажмите на watermark."
    desc.TextColor3 = Color3.fromRGB(200,200,200)
    desc.TextScaled = true
    desc.Font = Enum.Font.Gotham
    desc.TextWrapped = true
