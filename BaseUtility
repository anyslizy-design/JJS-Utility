-- Nimb (нимб)
local function createNimb(character)
	if not character then return end
	local head = character:FindFirstChild("Head")
	if not head then return end
	if nimbModel then nimbModel:Destroy() end

	local model = Instance.new("Model")
	model.Name = "Nimb"

	local ring = Instance.new("Part")
	ring.Name = "Ring"
	ring.Shape = Enum.PartType.Cylinder
	ring.Size = Vector3.new(4, 0.2, 4)
	ring.Material = Enum.Material.Neon
	ring.Transparency = 0.3
	ring.CanCollide = false
	ring.Anchored = false
	ring.Parent = model

	ring.Position = head.Position + Vector3.new(0, 1.5, 0)

	local weld = Instance.new("Weld")
	weld.Part0 = head
	weld.Part1 = ring
	weld.C0 = CFrame.new(0, 1.5, 0)
	weld.Parent = ring

	model.Parent = character

	local colors = {
		Color3.fromRGB(255,0,0), Color3.fromRGB(255,127,0), Color3.fromRGB(255,255,0),
		Color3.fromRGB(0,255,0), Color3.fromRGB(0,0,255), Color3.fromRGB(75,0,130),
		Color3.fromRGB(148,0,211)
	}
	local ci, ct, cs = 1, 0, 0.5
	local nextc = colors[2]
	if nimbColorConnection then nimbColorConnection:Disconnect() end
	nimbColorConnection = RunService.RenderStepped:Connect(function(dt)
		if not model or not model.Parent then
			nimbColorConnection:Disconnect()
			return
		end
		ct = ct + dt * cs
		if ct >= 1 then ct = 0 ci = ci % #colors + 1 nextc = colors[(ci % #colors) + 1] end
		ring.Color = colors[ci]:Lerp(nextc, ct)
	end)

	return model
end

local function toggleNimb()
	if nimbActive then
		if nimbModel then nimbModel:Destroy() end
		if nimbColorConnection then nimbColorConnection:Disconnect() end
		if nimbCharacterAddedConn then nimbCharacterAddedConn:Disconnect() end
		nimbActive = false
		if nimbButton then
			nimbButton.BackgroundColor3 = Color3.fromRGB(80,80,80)
		end
	else
		local char = LocalPlayer.Character
		if char then nimbModel = createNimb(char) end
		nimbCharacterAddedConn = LocalPlayer.CharacterAdded:Connect(function(c)
			if nimbActive then
				if nimbModel then nimbModel:Destroy() end
				nimbModel = createNimb(c)
			end
		end)
		nimbActive = true
		if nimbButton then
			nimbButton.BackgroundColor3 = Color3.fromRGB(128,0,128)
		end
	end
end

-- Atmosphere
local function toggleAtmosphere()
	if atmosphereActive then
		if originalLighting.Ambient then
			Lighting.Ambient = originalLighting.Ambient
			Lighting.OutdoorAmbient = originalLighting.OutdoorAmbient
			Lighting.Brightness = originalLighting.Brightness
			Lighting.ColorShift_Top = originalLighting.ColorShift_Top
			Lighting.ColorShift_Bottom = originalLighting.ColorShift_Bottom
		end
		if originalSky then originalSky.Parent = Lighting end
		atmosphereActive = false
	else
		if next(originalLighting) == nil then
			originalLighting.Ambient = Lighting.Ambient
			originalLighting.OutdoorAmbient = Lighting.OutdoorAmbient
			originalLighting.Brightness = Lighting.Brightness
			originalLighting.ColorShift_Top = Lighting.ColorShift_Top
			originalLighting.ColorShift_Bottom = Lighting.ColorShift_Bottom
		end
		originalSky = Lighting:FindFirstChildOfClass("Sky")
		if originalSky then originalSky.Parent = nil end
		Lighting.Ambient = Color3.new(0,0,0)
		Lighting.OutdoorAmbient = Color3.new(0,0,0)
		Lighting.Brightness = 0
		Lighting.ColorShift_Top = Color3.new(0,0,0)
		Lighting.ColorShift_Bottom = Color3.new(0,0,0)
		atmosphereActive = true
	end
end

