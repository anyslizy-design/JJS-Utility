local function populateTabs(tabs)
    -- Функция создания кнопки
    local function createButton(text, func, container, funcName)
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, -10, 0, 40) -- ширина подстроится под сетку
        btn.BackgroundColor3 = Color3.fromRGB(60,60,60)
        btn.Text = text
        btn.TextColor3 = Color3.new(1,1,1)
        btn.Font = Enum.Font.GothamBold
        btn.TextScaled = true
        btn.Parent = container
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0,8)
        btn.MouseButton1Click:Connect(func)
        btn.MouseButton2Click:Connect(function() startBindingForFunction(func, btn, text) end)
        buttons[funcName] = btn
        return btn
    end

    -- Combat
    createButton("TP Behind", tpBehind, tabs.combat, "tp")
    createButton("Aimbot", toggleAimbot, tabs.combat, "aimbot")

    -- Visuals
    createButton("Doza", toggleDoza, tabs.visuals, "doza")
    createButton("Atmosphere", toggleAtmosphere, tabs.visuals, "atmosphere")
    createButton("Nimb", toggleNimb, tabs.visuals, "nimb")
    createButton("Custom Fog", toggleCustomFog, tabs.visuals, "customFog")
    createButton("M1 Effect", toggleM1Effect, tabs.visuals, "m1Effect")
    createButton("Crosshair", toggleCrosshair, tabs.visuals, "crosshair")
    createButton("BF Notif", toggleBfNotif, tabs.visuals, "bfNotif")

    -- World, Misc, Configs пока пустые

    -- Обновим CanvasSize для каждой вкладки (кроме info)
    local function updateCanvas(frame)
        local totalHeight = 0
        for _, child in ipairs(frame:GetChildren()) do
            if child:IsA("TextButton") then
                totalHeight = totalHeight + child.AbsoluteSize.Y + 5
            end
        end
        frame.CanvasSize = UDim2.new(0,0,0,totalHeight)
    end

    updateCanvas(tabs.combat)
    updateCanvas(tabs.visuals)
end

-- ------------------------------------------------------------
-- Сборка UI и загрузка сохранённых состояний
-- ------------------------------------------------------------
local function buildUI()
    -- Создаём водяной знак
    watermark, _ = createWatermark()

    -- Создаём главное окно
    local mainGui, window = createMainWindow()
    menuGui = mainGui
    mainWindow = window

    -- Создаём нижнюю надпись и прикрепляем к главному GUI
    bottomLabel = createBottomLabel()
    bottomLabel.Parent = menuGui

    -- Создаём панель с вкладками
    local panelGui, panelFrame, tabButtons = createTabPanel()
    panel = panelFrame

    -- Создаём контейнеры для вкладок внутри главного окна
    local tabs = createTabFrames(mainWindow)

    -- Заполняем вкладки кнопками
    populateTabs(tabs)

    -- Делаем первую вкладку видимой
    tabs.combat.Visible = true
    tabButtons[1].BackgroundColor3 = Color3.fromRGB(80,80,80) -- подсветка активной вкладки

    -- Функция переключения вкладок
    local function switchTab(index)
        for i, btn in ipairs(tabButtons) do
            btn.BackgroundColor3 = (i == index) and Color3.fromRGB(80,80,80) or Color3.fromRGB(60,60,60)
        end
        local frames = {tabs.combat, tabs.visuals, tabs.world, tabs.misc, tabs.info, tabs.configs}
        for i, frame in ipairs(frames) do
            frame.Visible = (i == index)
        end
    end

    -- Привязываем кнопки к переключению
    for i, btn in ipairs(tabButtons) do
        btn.MouseButton1Click:Connect(function() switchTab(i) end)
    end

    -- Перетаскивание панели
    local dragging = false
    local dragStart, startPos, dragInput

    local function updateDrag(input)
        local delta = input.Position - dragStart
        local newX = startPos.X.Offset + delta.X
        local viewport = Camera.ViewportSize
        newX = math.clamp(newX, 10, viewport.X - PANEL_WIDTH - 10)
        panelFrame.Position = UDim2.new(0, newX, startPos.Y.Scale, startPos.Y.Offset)
    end

    local function finalizeDrag()
        local currentX = panelFrame.Position.X.Offset
        local windowLeft = (Camera.ViewportSize.X - WINDOW_WIDTH)/2
        local windowRight = windowLeft + WINDOW_WIDTH
        local leftTarget = windowLeft - PANEL_WIDTH - 10
        local rightTarget = windowRight + 10
        local distToLeft = math.abs(currentX - leftTarget)
        local distToRight = math.abs(currentX - rightTarget)
        if distToLeft < distToRight then
            panelFrame.Position = UDim2.new(0, leftTarget, panelFrame.Position.Y.Scale, panelFrame.Position.Y.Offset)
        else
            panelFrame.Position = UDim2.new(0, rightTarget, panelFrame.Position.Y.Scale, panelFrame.Position.Y.Offset)
        end
    end

    local dragBar = panelFrame:FindFirstChildOfClass("Frame") -- dragBar
    dragBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = panelFrame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                    finalizeDrag()
                end
            end)
        end
    end)

    dragBar.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            dragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            updateDrag(input)
        end
    end)

    -- Загружаем сохранённые состояния
    local states = loadStates()
    if states.doza then toggleDoza() end
    if states.atmosphere then toggleAtmosphere() end
    if states.nimb then toggleNimb() end
    if states.customFog then toggleCustomFog() end
    if states.m1Effect then toggleM1Effect() end
    if states.aimbot then toggleAimbot() end
    if states.crosshair then toggleCrosshair() end
    if states.bfNotif then toggleBfNotif() end
end

-- ------------------------------------------------------------
-- Глобальный ввод (бинды и открытие/закрытие меню)
-- ------------------------------------------------------------
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if isBinding then
        if input.UserInputType == Enum.UserInputType.Keyboard then
            local key = input.KeyCode
            if key ~= Enum.KeyCode.Unknown then
                local old = bindingFuncs[bindingFunc]
                if old then bindings[old] = nil; bindingFuncs[bindingFunc] = nil end
                bindings[key] = bindingFunc
                bindingFuncs[bindingFunc] = key
                if bindingButton and bindingBaseText then
                    updateButtonText(bindingButton, bindingBaseText, bindingFunc)
                end
                hideBindingPrompt()
                isBinding = false
                bindingFunc, bindingButton, bindingBaseText = nil, nil, nil
            end
        end
        return
    end
    if bindings[input.KeyCode] then
        bindings[input.KeyCode]()
    end
    if input.KeyCode == Enum.KeyCode.P then
        if isMinimized then
            restore()
        else
            minimize()
        end
    end
end)

-- Запуск
buildUI()
