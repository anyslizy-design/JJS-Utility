-- M1 Effect
local function createM1Circle()
	if currentCircle then
		currentCircle:Remove()
		currentCircle = nil
	end

	local circle = Drawing.new("Circle")
	circle.Thickness = 3
	circle.NumSides = 64
	circle.Radius = 0
	circle.Filled = false
	circle.Transparency = 1
	circle.Color = Color3.new(1,0,0)
	circle.Visible = true
	circle.Position = Vector2.new(0,0)
	currentCircle = circle
	circleStartTime = tick()

	local colors = {
		Color3.fromRGB(255,0,0), Color3.fromRGB(255,127,0), Color3.fromRGB(255,255,0),
		Color3.fromRGB(0,255,0), Color3.fromRGB(0,0,255), Color3.fromRGB(75,0,130),
		Color3.fromRGB(148,0,211)
	}
	local colorIdx = 1

	local connection
	connection = RunService.RenderStepped:Connect(function()
		if not currentCircle then
			connection:Disconnect()
			return
		end
		local elapsed = tick() - circleStartTime
		if elapsed > 1 then
			currentCircle:Remove()
			currentCircle = nil
			connection:Disconnect()
			return
		end
		local t = elapsed / 1
		local radius = t * 100
		local transparency = 1 - t
		currentCircle.Radius = radius
		currentCircle.Transparency = transparency
		colorIdx = math.floor(t * #colors) % #colors + 1
		currentCircle.Color = colors[colorIdx]
		local char = LocalPlayer.Character
		if char and char:FindFirstChild("HumanoidRootPart") then
			local pos = char.HumanoidRootPart.Position
			local v, onScreen = Camera:WorldToViewportPoint(pos)
			if onScreen then
				currentCircle.Position = Vector2.new(v.X, v.Y)
			end
		end
	end)
end

local function toggleM1Effect()
	if m1EffectActive then
		m1EffectActive = false
		if m1EffectConn then
			m1EffectConn:Disconnect()
			m1EffectConn = nil
		end
	else
		m1EffectActive = true
		m1EffectConn = UserInputService.InputBegan:Connect(function(input, gp)
			if gp then return end
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				createM1Circle()
			end
		end)
	end
end

-- Lock On Player (аимбот)
local function lockOnUpdate()
	local myChar = LocalPlayer.Character
	if not myChar then return end
	local myRoot = myChar:FindFirstChild("HumanoidRootPart")
	if not myRoot then return end

	local closestPlayer = nil
	local closestDist = math.huge
	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
			local dist = (player.Character.HumanoidRootPart.Position - myRoot.Position).Magnitude
			if dist < closestDist then
				closestDist = dist
				closestPlayer = player
			end
		end
	end

	if closestPlayer and closestPlayer.Character then
		local targetRoot = closestPlayer.Character.HumanoidRootPart
		-- Наводим камеру на цель
		local lookAt = CFrame.lookAt(Camera.CFrame.Position, targetRoot.Position)
		Camera.CFrame = lookAt
	end
end

local function toggleLockOn()
	if lockOnActive then
		lockOnActive = false
		if lockOnConnection then
			lockOnConnection:Disconnect()
			lockOnConnection = nil
		end
	else
		lockOnActive = true
		lockOnConnection = RunService.RenderStepped:Connect(lockOnUpdate)
	end
end

-- Custom Crosshair (радужный прицел)
local function createCrosshair()
	if crosshairDrawing then return end

	local cross = Drawing.new("Circle")
	cross.Thickness = 2
	cross.NumSides = 16
	cross.Radius = 8
	cross.Filled = false
	cross.Color = Color3.new(1,0,0)
	cross.Visible = true
	cross.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
	crosshairDrawing = cross

	-- Радужная смена цвета
	local colors = {
		Color3.fromRGB(255,0,0), Color3.fromRGB(255,127,0), Color3.fromRGB(255,255,0),
		Color3.fromRGB(0,255,0), Color3.fromRGB(0,0,255), Color3.fromRGB(75,0,130),
		Color3.fromRGB(148,0,211)
	}
	local ci, ct, cs = 1, 0, 1.0
	local nextc = colors[2]
	crosshairColorConnection = RunService.RenderStepped:Connect(function(dt)
		if not crosshairDrawing or not crosshairActive then
			crosshairColorConnection:Disconnect()
			return
		end
		ct = ct + dt * cs
		if ct >= 1 then
			ct = 0
			ci = ci % #colors + 1
			nextc = colors[(ci % #colors) + 1]
		end
		crosshairDrawing.Color = colors[ci]:Lerp(nextc, ct)
		-- Обновляем позицию (на случай изменения размера окна)
		crosshairDrawing.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
	end)
end

local function toggleCrosshair()
	if crosshairActive then
		crosshairActive = false
		if crosshairDrawing then
			crosshairDrawing:Remove()
			crosshairDrawing = nil
		end
		if crosshairColorConnection then
			crosshairColorConnection:Disconnect()
			crosshairColorConnection = nil
		end
	else
		crosshairActive = true
		createCrosshair()
	end
end

-- TP Behind
local function tpBehind()
	local char = LocalPlayer.Character
	if not char then return end
	local root = char:FindFirstChild("HumanoidRootPart")
	if not root then return end

	local closest, dist = nil, math.huge
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
			local d = (p.Character.HumanoidRootPart.Position - root.Position).Magnitude
			if d < dist then dist = d; closest = p end
		end
	end
	if closest and closest.Character then
		local targetRoot = closest.Character.HumanoidRootPart
		local behind = targetRoot.Position - targetRoot.CFrame.LookVector * 5
		root.CFrame = CFrame.new(behind, behind + targetRoot.CFrame.LookVector)
	end
end

