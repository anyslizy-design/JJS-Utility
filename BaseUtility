-- ========== TAB BUTTONS (LEFT PANEL) ==========
local buttonSpacing = 10
local buttonPadding = 15
local activeColor = Color3.fromRGB(138, 43, 226)    -- purple for active tab
local inactiveColor = Color3.fromRGB(60, 60, 60)    -- dark gray for inactive tabs
local textColor = Color3.fromRGB(255, 255, 255)     -- white text

-- Calculate button height to fill the left panel without empty space
local availableHeight = windowHeight - 2 * buttonPadding - 4 * buttonSpacing
local buttonSize = availableHeight / 5  -- = 91

-- List of tabs
local tabs = {"Combat", "Misc", "World", "Player", "Config"}

-- We'll store buttons and content frames in tables
local buttons = {}
local contentFrames = {}

-- Function to create a tab button
local function createTabButton(name, positionY)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1, -buttonPadding*2, 0, buttonSize)
	btn.Position = UDim2.new(0, buttonPadding, 0, positionY)
	btn.Text = name
	btn.TextColor3 = textColor
	btn.Font = Enum.Font.GothamSemibold
	btn.TextScaled = true
	btn.BorderSizePixel = 0
	btn.AutoButtonColor = false
	btn.Parent = leftPanel

	local btnCorner = Instance.new("UICorner")
	btnCorner.CornerRadius = UDim.new(0, 8)
	btnCorner.Parent = btn

	return btn
end

-- Create buttons dynamically (they will fill the entire height)
for i, tabName in ipairs(tabs) do
	local yPos = buttonPadding + (i-1) * (buttonSize + buttonSpacing)
	local btn = createTabButton(tabName, yPos)
	buttons[tabName] = btn
end

-- ========== CONTENT FRAMES (RIGHT PANEL) ==========
-- Create a content frame for each tab (initially all invisible except the first)
for _, tabName in ipairs(tabs) do
	local content = Instance.new("Frame")
	content.Size = UDim2.new(1, -buttonPadding*2, 1, -buttonPadding*2)
	content.Position = UDim2.new(0, buttonPadding, 0, buttonPadding)
	content.BackgroundTransparency = 1
	content.BorderSizePixel = 0
	content.Visible = false  -- start hidden
	content.Parent = rightPanel
	contentFrames[tabName] = content
end

