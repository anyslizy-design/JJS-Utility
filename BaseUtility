-- Функция создания радужной самурайской шляпы (с плавной сменой цветов)
local function createChinaHat(character)
	if not character then return end
	local head = character:FindFirstChild("Head")
	if not head then return end

	-- Удаляем старую шляпу
	if hatModel then
		hatModel:Destroy()
		hatModel = nil
	end

	-- Создаём MeshPart самурайской шляпы (ID взят из библиотеки Roblox)
	local hat = Instance.new("MeshPart")
	hat.MeshId = "rbxassetid://169697502"  -- Samurai Hat
	hat.TextureID = "rbxassetid://169697502" -- та же текстура
	hat.Material = Enum.Material.Neon
	hat.Transparency = 0.3
	hat.Size = Vector3.new(2, 1.5, 2)  -- подгоняем размер
	hat.CanCollide = false
	hat.Anchored = false
	hat.Name = "ChinaHat"

	-- Позиционируем на голове
	hat.Position = head.Position + Vector3.new(0, 0.8, 0)  -- немного выше

	-- Крепим к голове
	local weld = Instance.new("Weld")
	weld.Part0 = head
	weld.Part1 = hat
	weld.C0 = CFrame.new(0, 0.8, 0)  -- смещение
	weld.Parent = hat

	hat.Parent = character

	-- Плавная смена цветов
	local colors = {
		Color3.fromRGB(255, 0, 0),
		Color3.fromRGB(255, 127, 0),
		Color3.fromRGB(255, 255, 0),
		Color3.fromRGB(0, 255, 0),
		Color3.fromRGB(0, 0, 255),
		Color3.fromRGB(75, 0, 130),
		Color3.fromRGB(148, 0, 211)
	}
	local index = 1
	local nextColor = colors[2]  -- для интерполяции
	local t = 0
	local speed = 0.5  -- скорость перехода (чем меньше, тем плавнее)

	if hatColorConnection then
		hatColorConnection:Disconnect()
	end
	hatColorConnection = RunService.RenderStepped:Connect(function(dt)
		if not hat or not hat.Parent then
			hatColorConnection:Disconnect()
			hatColorConnection = nil
			return
		end
		-- Плавно меняем цвет от текущего к следующему
		t = t + dt * speed
		if t >= 1 then
			t = 0
			index = index % #colors + 1
			nextColor = colors[(index % #colors) + 1]
		end
		local currentColor = colors[index]:Lerp(nextColor, t)
		hat.Color = currentColor
	end)

	return hat
end

