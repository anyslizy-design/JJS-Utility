-- Вспомогательная функция для обновления текста кнопки
local function updateButtonText(button, baseText, func)
	local keyCode = bindingFuncs[func]
	if keyCode then
		local keyName = keyCode.Name:gsub("KeyCode%.", "")
		button.Text = baseText .. " [" .. keyName .. "]"
	else
		button.Text = baseText
	end
end

