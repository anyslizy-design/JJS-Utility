-- Закрытие меню (без выгрузки)
local function closeMenu()
	if not menuOpen then return end
	local tweenInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	local goal = {BackgroundTransparency = 1, TextTransparency = 1}
	for _, v in ipairs(menuGui:GetDescendants()) do
		if v:IsA("Frame") or v:IsA("TextLabel") or v:IsA("TextButton") then
			TweenService:Create(v, tweenInfo, goal):Play()
		end
	end
	task.wait(0.3)
	menuGui:Destroy()
	menuOpen = false
	menuGui = nil
	mainFrame = nil
end

-- Глобальный ввод
UserInputService.InputBegan:Connect(function(input, gp)
	if gp then return end
	if isBinding then
		if input.UserInputType == Enum.UserInputType.Keyboard then
			local key = input.KeyCode
			if key ~= Enum.KeyCode.Unknown then
				local old = bindingFuncs[bindingFunc]
				if old then bindings[old] = nil; bindingFuncs[bindingFunc] = nil end
				bindings[key] = bindingFunc
				bindingFuncs[bindingFunc] = key
				if bindingButton and bindingBaseText then
					updateButtonText(bindingButton, bindingBaseText, bindingFunc)
				end
				hideBindingPrompt()
				isBinding = false
				bindingFunc, bindingButton, bindingBaseText = nil, nil, nil
			end
		end
		return
	end
	if bindings[input.KeyCode] then bindings[input.KeyCode]() end
	if input.KeyCode == Enum.KeyCode.P then
		if menuOpen then closeMenu() else openMenu() end
	end
	if input.KeyCode == Enum.KeyCode.RightShift and menuOpen then closeMenu() end
end)

